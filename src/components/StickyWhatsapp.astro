---
// Subtiele mobiele sticky-CTA onderaan (alleen mobiel). Link naar WhatsApp met
// voorgevulde tekst in de taal van de bezoeker.
import { waLink } from '../data/site';
import { standaardTaal, type Taal } from '../i18n/config';
import Icon from './Icon.astro';

interface Props { taal?: Taal }
const { taal = standaardTaal } = Astro.props;

const teksten: Record<Taal, { label: string; bericht: string }> = {
  nl: { label: 'Stel uw vraag via WhatsApp', bericht: 'Hallo Maghreb Estates, ik heb een vraag over vastgoed in Marokko.' },
  en: { label: 'Ask your question on WhatsApp', bericht: 'Hello Maghreb Estates, I have a question about property in Morocco.' },
  fr: { label: 'Posez votre question sur WhatsApp', bericht: 'Bonjour Maghreb Estates, j’ai une question sur l’immobilier au Maroc.' },
  ar: { label: 'اطرح سؤالك عبر واتساب', bericht: 'مرحباً Maghreb Estates، لدي سؤال حول العقارات في المغرب.' },
};
const { label, bericht } = teksten[taal];
---
<a class="sticky-wa" href={waLink(bericht)} rel="noopener" aria-label={label}>
  <Icon name="whatsapp" size={18} />
  <span>{label}</span>
</a>

---
// Subtiele mobiele sticky-CTA onderaan (alleen mobiel). Link naar WhatsApp met
// voorgevulde tekst. Geen emoji, professioneel, niet over formulieren heen
// (body krijgt op mobiel padding-bottom in global.css).
import { waLink } from '../data/site';
import Icon from './Icon.astro';
const href = waLink('Hallo Maghreb Estates, ik heb een vraag over vastgoed in Marokko.');
---
<a class="sticky-wa" href={href} rel="noopener" aria-label="Stel een vraag via WhatsApp">
  <Icon name="chat" size={18} />
  <span>Stel je vraag via WhatsApp</span>
</a>

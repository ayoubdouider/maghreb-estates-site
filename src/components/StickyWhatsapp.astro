---
// Subtiele mobiele sticky-CTA onderaan (alleen mobiel). Link naar WhatsApp met
// voorgevulde tekst. Geen emoji, professioneel, niet over formulieren heen
// (body krijgt op mobiel padding-bottom in global.css).
import { waLink } from '../data/site';
import Icon from './Icon.astro';
const href = waLink('Hallo Maghreb Estates, ik wil graag een woning of project in Marokko laten controleren. Kunnen jullie meekijken?');
---
<a class="sticky-wa" href={href} rel="noopener" aria-label="Stuur een woninglink via WhatsApp">
  <Icon name="chat" size={18} />
  <span>Stuur woninglink via WhatsApp</span>
</a>

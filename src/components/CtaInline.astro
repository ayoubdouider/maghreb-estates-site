---
interface Props { title?: string; text?: string; label?: string; href?: string; }
const {
  title = 'Plan een adviesgesprek',
  text = 'In maximaal een uur bespreken wij uw doel, budget en de logische vervolgstap.',
  label = 'Plan adviesgesprek',
  href = '/adviesgesprek/',
} = Astro.props;
---
<div class="cta-inline">
  <div>
    <h3>{title}</h3>
    <p>{text}</p>
  </div>
  <a href={href} class="btn btn--primary">{label}</a>
</div>

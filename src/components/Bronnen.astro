---
// "Bronnen en marktinformatie" — transparantieblok. Voorlopig voorzichtig; ruimte
// voor officiële bronnen zodra beschikbaar. Geen verzonnen cijfers.
interface Props { extra?: string[]; }
const standaard = [
  'Bank Al-Maghrib — macro-economische en rente-informatie',
  'ANCFCC — kadaster en eigendomsregistratie (titre foncier)',
  'Direction Générale des Impôts (DGI) — belasting- en registratieregels',
  'Publieke marktreferenties (o.a. Agenz, Yakeey) voor prijsoriëntatie',
  'Eigen objectanalyses en marktdata van Maghreb Estates',
];
const items = [...standaard, ...(Astro.props.extra ?? [])];
---
<div class="bronnen container" style="max-width:760px">
  <h3>Bronnen en marktinformatie</h3>
  <ul>
    {items.map((i) => <li>{i}</li>)}
  </ul>
  <p>Cijfers en tarieven zijn indicatief en kunnen wijzigen. Wij verwerken officiële en actuele bronnen zodra beschikbaar en verifiëren belangrijke bedragen per dossier bij notaris, bank of fiscalist. Geen fiscaal, juridisch of beleggingsadvies.</p>
</div>

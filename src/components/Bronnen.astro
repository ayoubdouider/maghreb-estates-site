---
// "Bronnen en marktinformatie" — transparant, zonder valse referenties.
// We tonen brontypen (geen verzonnen bronlinks). `extra` voegt paginaspecifieke
// nuance toe (bv. per stad de gebruikte platformen).
interface Props { extra?: string[]; }
const extra = Astro.props.extra ?? [];
---
<div class="bronnen container" style="max-width:760px">
  <h3>Bronnen en marktinformatie</h3>
  <p>Gebruikte brontypen: publieke marktdata, officiële registraties waar beschikbaar, platformdata en objectvergelijkingen.</p>
  {extra.length > 0 && (
    <ul>
      {extra.map((i) => <li>{i}</li>)}
    </ul>
  )}
  <p>Cijfers en tarieven zijn indicatief en kunnen wijzigen. Wij controleren belangrijke bedragen per dossier bij notaris, bank of fiscalist. Deze informatie is geen fiscaal, juridisch of beleggingsadvies.</p>
</div>

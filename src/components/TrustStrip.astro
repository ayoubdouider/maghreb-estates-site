---
import Icon from './Icon.astro';
// Vaste trust-elementen die op belangrijke pagina's terugkomen.
const items = [
  { icon: 'taal', t: 'Nederlandstalige begeleiding', s: 'Eén vast aanspreekpunt dat uw taal spreekt.' },
  { icon: 'afstand', t: 'Lokale controle in Marokko', s: 'Wij staan ter plaatse en kennen de markt.' },
  { icon: 'schild', t: 'Dossiercheck vóór betaling', s: 'Titre foncier en contract eerst gecontroleerd.' },
  { icon: 'beheer', t: 'Beheer na aankoop', s: 'Toezicht, verhuur en onderhoud op afstand.' },
];
---
<section class="section" style="padding-block:52px">
  <div class="container">
    <div class="trust-strip">
      {items.map((i) => (
        <div class="trust-strip__item">
          <span class="trust-strip__ic"><Icon name={i.icon} size={22} /></span>
          <div>
            <strong>{i.t}</strong>
            <span>{i.s}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

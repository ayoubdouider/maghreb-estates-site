---
import Icon from './Icon.astro';
// Vaste trust-elementen die op belangrijke pagina's terugkomen.
const items = [
  { icon: 'grafiek', t: 'Datagedreven analyse', s: 'Prijsvergelijking, marktdata en objectbeoordeling.' },
  { icon: 'afstand', t: 'Lokale aanwezigheid', s: 'Ter plaatse in Marokko, met een lokaal netwerk.' },
  { icon: 'schild', t: 'Due diligence vóór aankoop', s: 'Documenten, eigendom en contract eerst beoordeeld.' },
  { icon: 'taal', t: 'Meertalige begeleiding', s: 'Nederlands, Engels, Frans en Arabisch/Darija.' },
];
---
<section class="section" style="padding-block:52px">
  <div class="container">
    <div class="trust-strip">
      {items.map((i) => (
        <div class="trust-strip__item">
          <span class="trust-strip__ic"><Icon name={i.icon} size={22} /></span>
          <div>
            <strong>{i.t}</strong>
            <span>{i.s}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

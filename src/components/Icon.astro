---
// Strakke inline-SVG line-icons (stroke, currentColor). Vervangt alle emoji.
// Gebruik: <Icon name="titel" /> of <Icon name="check" size={20} />
interface Props { name: string; size?: number; class?: string; }
const { name, size = 24, class: klass = '' } = Astro.props;

// 24x24 viewBox, stroke 1.6, ronde uiteinden. Alleen <path>/<circle>/<rect> per icoon.
const icons: Record<string, string> = {
  // Eigendomstitel / geregistreerd document met zegel
  titel: '<path d="M7 3h7l5 5v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z"/><path d="M14 3v5h5"/><circle cx="12" cy="14" r="2.5"/><path d="M10.5 16.2 9.5 20l2.5-1.5L14.5 20l-1-3.8"/>',
  // Koopcontract / document met regels
  contract: '<path d="M7 3h7l5 5v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z"/><path d="M14 3v5h5"/><path d="M9 12h7M9 15.5h7M9 8.5h3"/>',
  // Prijs / locatie — prijskaartje
  prijs: '<path d="M12.6 3H20a1 1 0 0 1 1 1v7.4a1 1 0 0 1-.3.7l-8.6 8.6a1 1 0 0 1-1.4 0l-7.4-7.4a1 1 0 0 1 0-1.4l8.6-8.6a1 1 0 0 1 .7-.3Z"/><circle cx="16.5" cy="7.5" r="1.3"/>',
  // Notaris / overdracht — instituut met zuilen
  notaris: '<path d="M3 9.5 12 4l9 5.5"/><path d="M4.5 9.5V19M9 9.5V19M15 9.5V19M19.5 9.5V19"/><path d="M3 19h18M4.5 21.5h15"/>',
  // Beheer — huis
  beheer: '<path d="M4 11.5 12 5l8 6.5"/><path d="M6 10.5V20h12v-9.5"/><path d="M10 20v-5h4v5"/>',
  // Sleutel
  sleutel: '<circle cx="8" cy="8" r="4"/><path d="m11 11 8 8M16 16l2-2M18.5 18.5l1.5-1.5"/>',
  // Op afstand — map-pin
  afstand: '<path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/>',
  // Check
  check: '<path d="m4 12.5 5 5L20 6.5"/>',
  // Telefoon
  telefoon: '<path d="M4 5c0-1 .8-2 2-2h2l1.5 4-2 1.5a13 13 0 0 0 6 6l1.5-2 4 1.5V18c0 1.1-.9 2-2 2A16 16 0 0 1 4 5Z"/>',
  // Mail
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3.5 7 8.5 6 8.5-6"/>',
  // Chat (WhatsApp-neutraal)
  chat: '<path d="M4 12a8 8 0 1 1 3.5 6.6L4 20l1.4-3.5A7.9 7.9 0 0 1 4 12Z"/>',
  // WhatsApp — officieel merkicoon (gevuld pad, zie `gevuld` hieronder)
  whatsapp: '<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>',
  // Kalender — adviesgesprek / tijdslot
  kalender: '<rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18M8 3v4M16 3v4"/>',
  // Grafiek — marktvergelijking / data
  grafiek: '<path d="M4 20V10M10 20V4M16 20v-7M22 20H2"/>',
  // Weegschaal — objectscore / beoordeling
  weegschaal: '<path d="M12 4v16M7 20h10M5 8h14"/><path d="M5 8 2.5 14h5L5 8ZM19 8l-2.5 6h5L19 8Z"/>',
  // Dashboard — rapportage
  dashboard: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>',
  // LinkedIn
  linkedin: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 10v7M7 7v.01M11 17v-4a2 2 0 0 1 4 0v4M11 17v-7"/>',
  // Waarschuwing
  alert: '<path d="M12 4 2.5 20h19L12 4Z"/><path d="M12 10v4M12 17v.01"/>',
  // Schild (vertrouwen)
  schild: '<path d="M12 3 5 6v6c0 4 3 6.5 7 8 4-1.5 7-4 7-8V6l-7-3Z"/><path d="m9 12 2 2 4-4"/>',
  // Vlag/taal — spraak
  taal: '<path d="M4 5h16v10H9l-4 4V5Z"/><path d="M8 9h8M8 12h5"/>',
};
// Merkiconen zijn gevulde paden en mogen geen stroke krijgen.
const gevuld = new Set(['whatsapp']);
const d = icons[name] ?? '';
const isGevuld = gevuld.has(name);
---
{d && (
  <svg
    class={klass}
    width={size} height={size} viewBox="0 0 24 24"
    fill={isGevuld ? 'currentColor' : 'none'}
    stroke={isGevuld ? 'none' : 'currentColor'}
    stroke-width={isGevuld ? undefined : 1.6}
    stroke-linecap={isGevuld ? undefined : 'round'}
    stroke-linejoin={isGevuld ? undefined : 'round'}
    aria-hidden="true" set:html={d}
  />
)}

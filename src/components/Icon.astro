---
// Strakke inline-SVG line-icons (stroke, currentColor). Vervangt alle emoji.
// Gebruik: <Icon name="titel" /> of <Icon name="check" size={20} />
interface Props { name: string; size?: number; class?: string; }
const { name, size = 24, class: klass = '' } = Astro.props;

// 24x24 viewBox, stroke 1.6, ronde uiteinden. Alleen <path>/<circle>/<rect> per icoon.
const icons: Record<string, string> = {
  // Eigendomstitel / geregistreerd document met zegel
  titel: '<path d="M7 3h7l5 5v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z"/><path d="M14 3v5h5"/><circle cx="12" cy="14" r="2.5"/><path d="M10.5 16.2 9.5 20l2.5-1.5L14.5 20l-1-3.8"/>',
  // Koopcontract / document met regels
  contract: '<path d="M7 3h7l5 5v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z"/><path d="M14 3v5h5"/><path d="M9 12h7M9 15.5h7M9 8.5h3"/>',
  // Prijs / locatie — prijskaartje
  prijs: '<path d="M12.6 3H20a1 1 0 0 1 1 1v7.4a1 1 0 0 1-.3.7l-8.6 8.6a1 1 0 0 1-1.4 0l-7.4-7.4a1 1 0 0 1 0-1.4l8.6-8.6a1 1 0 0 1 .7-.3Z"/><circle cx="16.5" cy="7.5" r="1.3"/>',
  // Notaris / overdracht — instituut met zuilen
  notaris: '<path d="M3 9.5 12 4l9 5.5"/><path d="M4.5 9.5V19M9 9.5V19M15 9.5V19M19.5 9.5V19"/><path d="M3 19h18M4.5 21.5h15"/>',
  // Beheer — huis
  beheer: '<path d="M4 11.5 12 5l8 6.5"/><path d="M6 10.5V20h12v-9.5"/><path d="M10 20v-5h4v5"/>',
  // Sleutel
  sleutel: '<circle cx="8" cy="8" r="4"/><path d="m11 11 8 8M16 16l2-2M18.5 18.5l1.5-1.5"/>',
  // Op afstand — map-pin
  afstand: '<path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/>',
  // Check
  check: '<path d="m4 12.5 5 5L20 6.5"/>',
  // Telefoon
  telefoon: '<path d="M4 5c0-1 .8-2 2-2h2l1.5 4-2 1.5a13 13 0 0 0 6 6l1.5-2 4 1.5V18c0 1.1-.9 2-2 2A16 16 0 0 1 4 5Z"/>',
  // Mail
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3.5 7 8.5 6 8.5-6"/>',
  // Chat (WhatsApp-neutraal)
  chat: '<path d="M4 12a8 8 0 1 1 3.5 6.6L4 20l1.4-3.5A7.9 7.9 0 0 1 4 12Z"/>',
  // LinkedIn
  linkedin: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 10v7M7 7v.01M11 17v-4a2 2 0 0 1 4 0v4M11 17v-7"/>',
  // Waarschuwing
  alert: '<path d="M12 4 2.5 20h19L12 4Z"/><path d="M12 10v4M12 17v.01"/>',
  // Schild (vertrouwen)
  schild: '<path d="M12 3 5 6v6c0 4 3 6.5 7 8 4-1.5 7-4 7-8V6l-7-3Z"/><path d="m9 12 2 2 4-4"/>',
  // Vlag/taal — spraak
  taal: '<path d="M4 5h16v10H9l-4 4V5Z"/><path d="M8 9h8M8 12h5"/>',
};
const d = icons[name] ?? '';
---
{d && (
  <svg
    class={klass}
    width={size} height={size} viewBox="0 0 24 24" fill="none"
    stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"
    aria-hidden="true" set:html={d}
  />
)}

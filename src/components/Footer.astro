---
import { site, legal, waLink } from '../data/site';
import Icon from './Icon.astro';
const jaar = new Date().getFullYear();

// Footer blijft bewust rustig: geen SEO-linkdump. Stadspagina's, kennisbank en
// long-tail gidsen zijn bereikbaar via /vastgoed-marokko/, /kennisbank/ en de
// sitemap. Vastgoedbeheer staat hier niet zolang die dienst niet operationeel is.
---
<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        {/* TODO: replace logo with transparent-background version from Canva. */}
        <span class="logo-word">Maghreb</span>
        <span class="logo-sub">ESTATES</span>
        <p>International real estate advisory in Morocco.</p>
      </div>

      <div>
        <h4>Contact</h4>
        <ul class="contactlist footer__contact">
          <li>
            <Icon name="telefoon" size={17} />
            <a href={`tel:${site.telefoonHref}`}>{site.telefoon}</a>
          </li>
          <li>
            <Icon name="whatsapp" size={17} />
            <a href={waLink('Hallo Maghreb Estates, ik heb een vraag over vastgoed in Marokko.')}>WhatsApp</a>
          </li>
          <li>
            <Icon name="mail" size={17} />
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </li>
        </ul>
        {/* Bedrijfsgegevens — officiële Marokkaanse inschrijving (SARL). */}
        <p class="footer__bedrijf">
          {site.adres}<br />
          {site.vestigingsplaats}<br />
          RC {site.rc} (Rabat) · ICE {site.ice}
        </p>
      </div>

      <div>
        <h4>Services</h4>
        <a href="/aankoopbegeleiding-vastgoed-marokko/">Aankoopbegeleiding</a>
        <a href="/investeren-vastgoed-marokko/">Investeringsadvies</a>
        <a href="/nieuwbouw-vastgoed-marokko/">Nieuwbouw &amp; off-plan</a>
        <a href="/huis-verkopen-marokko-vanuit-nederland/">Verkoopbegeleiding</a>
      </div>

      <div>
        <h4>Insights</h4>
        <a href="/kosten-huis-kopen-marokko/">Kosten bij aankoop</a>
        <a href="/juridische-documenten-vastgoed-marokko/">Juridische documenten</a>
        <a href="/kennisbank/">Kennisbank</a>

        <h4 style="margin-top:26px">Markets</h4>
        <a href="/vastgoed-marokko/">Alle markten</a>
      </div>
    </div>

    <div class="footer__bottom">
      <span>&copy; {jaar} {site.naam}. Alle rechten voorbehouden.</span>
      <span class="footer__legal">
        {legal.map((l, i) => <>{i > 0 && <span aria-hidden="true"> · </span>}<a href={l.href}>{l.label}</a></>)}
      </span>
    </div>
  </div>
</footer>

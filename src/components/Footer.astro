---
import { site, legal, waLink, homeMarkten } from '../data/site';
import Icon from './Icon.astro';
const jaar = new Date().getFullYear();
---
<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <span class="logo-word">Maghreb</span>
        <span class="logo-sub">ESTATES</span>
        <p>{site.tagline}</p>
        <ul class="contactlist" style="margin-top:16px">
          <li><Icon name="telefoon" size={16} /><a href={`tel:${site.telefoonHref}`}>{site.telefoon}</a></li>
          <li><Icon name="chat" size={16} /><a href={waLink('Hallo Maghreb Estates, ik heb een vraag over vastgoed in Marokko.')}>WhatsApp</a></li>
          <li><Icon name="mail" size={16} /><a href={`mailto:${site.email}`}>{site.email}</a></li>
        </ul>
        {/* Bedrijfsgegevens — officiële Marokkaanse inschrijving (SARL). */}
        {(site.vestigingsplaats || site.rc || site.ice) && (
          <p class="footer__bedrijf">
            Maghreb Estates {site.rechtsvorm}{site.activiteit && <> · {site.activiteit}</>}<br />
            {site.adres && <>{site.adres}<br /></>}
            {site.vestigingsplaats && <>{site.vestigingsplaats}<br /></>}
            {site.rc && <>RC {site.rc} (Rabat){site.ice && <> · ICE {site.ice}</>}</>}
          </p>
        )}
      </div>

      <div>
        <h4>Services</h4>
        <a href="/aankoopbegeleiding-vastgoed-marokko/">Aankoopbegeleiding</a>
        <a href="/nieuwbouw-vastgoed-marokko/">Nieuwbouw & off-plan</a>
        <a href="/investeren-vastgoed-marokko/">Investeringsadvies</a>
        <a href="/vastgoedbeheer-marokko/">Vastgoedbeheer</a>
        <a href="/huis-verkopen-marokko-vanuit-nederland/">Verkoopbegeleiding</a>
      </div>

      <div>
        <h4>Insights</h4>
        <a href="/kosten-huis-kopen-marokko/">Kosten bij aankoop</a>
        <a href="/risicos-huis-kopen-marokko/">Risico’s</a>
        <a href="/juridische-documenten-vastgoed-marokko/">Juridische documenten</a>
        <a href="/kennisbank/">Kennisbank</a>
      </div>

      <div>
        <h4>Markets</h4>
        {homeMarkten.map((s) => <a href={`/vastgoed-${s.slug}/`}>{s.naam}</a>)}
        <a href="/vastgoed-marokko/">Alle markten</a>
      </div>
    </div>

    <div class="footer__bottom">
      <span>&copy; {jaar} {site.naam}. Alle rechten voorbehouden.</span>
      <span class="footer__legal">
        {legal.map((l, i) => <>{i > 0 && <span aria-hidden="true"> · </span>}<a href={l.href}>{l.label}</a></>)}
      </span>
    </div>
  </div>
</footer>

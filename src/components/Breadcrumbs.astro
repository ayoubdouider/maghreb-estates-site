---
import { site } from '../data/site';
interface Crumb { label: string; href: string; }
interface Props {
  items: Crumb[];
  /** Beginpunt van het kruimelpad; vertaald op anderstalige pagina's. */
  home?: Crumb;
  label?: string;
}
const { items, home = { label: 'Home', href: '/' }, label = 'Kruimelpad' } = Astro.props;

// BreadcrumbList JSON-LD — start altijd bij de homepage van de eigen taal.
const full = [home, ...items];
const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: full.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    item: new URL(c.href, site.url).href,
  })),
};
---
<nav class="crumbs container" aria-label={label}>
  {full.map((c, i) => (
    <>
      {i > 0 && <span>/</span>}
      {i < full.length - 1 ? <a href={c.href}>{c.label}</a> : <strong>{c.label}</strong>}
    </>
  ))}
</nav>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />

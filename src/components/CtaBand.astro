---
interface Props { title?: string; text?: string; label?: string; href?: string; }
const {
  title = 'Uw mogelijkheden bespreken?',
  text = 'Plan een adviesgesprek met Maghreb Estates. In maximaal een uur brengen wij uw situatie, doel en vervolgstappen in kaart.',
  label = 'Plan adviesgesprek',
  href = '/adviesgesprek/',
} = Astro.props;
---
<section class="ctaband">
  <div class="container">
    <h2>{title}</h2>
    <p>{text}</p>
    <a href={href} class="btn btn--light">{label}</a>
  </div>
</section>

---
// Formaatvullende hero: de vastgoedfoto beslaat de volledige sectie, met een
// donkere gradient-overlay eroverheen zodat de crèmekleurige tekst leesbaar
// blijft.
//
// Beeldkeuze — alleen foto's van bestaand vastgoed:
// In gebruik zijn residentie-appartementen.webp, villa3.jpg, villa4.jpg en
// villa5.jpg. Dat zijn alle vier foto's, geen renders.
// De 3D-renders apt2.jpg, villa1.jpg en villa2.jpg staan nog wel in
// public/images maar worden bewust nergens meer gebruikt: op een pagina over
// bestaande bouw wekt een render de indruk dat een bestaand pand wordt
// getoond. Zet ze hooguit terug op nieuwbouw/off-plan, waar een
// projectimpressie de gangbare weergave is.
//
// TODO: laat professionele fotografie maken van echt vastgoed in Marokko
// (Tanger, Casablanca, Rabat, Marrakech, Agadir). Vereist voor een
// formaatvullende hero: liggend, minimaal 2000px breed (2400x1400 is ideaal),
// daglicht, rustige compositie met ruimte links voor de tekst. villa5.jpg
// draagt nu 28 pagina's, waaronder alle 18 stadspagina's — daar is spreiding
// het hardst nodig.
interface Cta { label: string; href: string; primary?: boolean; }
interface Props {
  eyebrow?: string;
  title: string;
  sub?: string;
  image?: string;
  compact?: boolean;
  ctas?: Cta[];
  trust?: string[];
}
const {
  eyebrow, title, sub, image = '/images/villa5.jpg',
  compact = false, ctas = [], trust = [],
} = Astro.props;
---
<section class={`hero ${compact ? 'hero--compact' : ''}`} style={`background-image: url('${image}')`}>
  <div class="hero__overlay"></div>
  <div class="container">
    <div class="hero__inner">
      {eyebrow && <p class="eyebrow eyebrow--light">{eyebrow}</p>}
      <h1 set:html={title} />
      {sub && <p class="hero__sub">{sub}</p>}
      {ctas.length > 0 && (
        <div class="hero__actions">
          {ctas.map((c) => (
            <a href={c.href} class={`btn ${c.primary ? 'btn--light' : 'btn--outline'}`}>{c.label}</a>
          ))}
        </div>
      )}
      {trust.length > 0 && (
        <div class="trustline">
          {trust.map((t) => <span>{t}</span>)}
        </div>
      )}
    </div>
  </div>
</section>

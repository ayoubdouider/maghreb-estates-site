---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyWhatsapp from '../components/StickyWhatsapp.astro';
import { site } from '../data/site';
import { htmlLang, isRtl, paginas, sleutelVoorPad, standaardTaal, talen, type Taal } from '../i18n/config';

// Mobiele sticky-WhatsApp niet tonen op juridische/bedankpagina's.
const geenSticky = ['/privacybeleid/', '/algemene-voorwaarden/', '/disclaimer/'];
const toonSticky = !geenSticky.includes(Astro.props.path ?? Astro.url.pathname);

interface Props {
  title: string;
  description: string;
  /** Pad zonder domein, bv. "/huis-kopen-marokko/". Default = huidige pagina. */
  path?: string;
  image?: string;
  /** Extra JSON-LD objecten (FAQPage, Service, Article, BreadcrumbList...) */
  schema?: object[];
  noindex?: boolean;
  /** Taal van de pagina. Default Nederlands, want dat is de hoofdtaal. */
  taal?: Taal;
}

const {
  title, description, image = site.ogImage, schema = [], noindex = false,
  taal = standaardTaal,
} = Astro.props;

const pad = Astro.props.path ?? Astro.url.pathname;
const canonical = new URL(pad, site.url).href;
const ogImageAbs = new URL(image, site.url).href;
const rtl = isRtl(taal);

// hreflang: alleen op pagina's die daadwerkelijk vertaald zijn. Alternates
// verzinnen voor pagina's die alleen in het Nederlands bestaan zou zoekmachines
// naar 404's sturen, dus dat doen we niet.
const sleutel = sleutelVoorPad(pad);
const alternates = sleutel
  ? talen.map((t) => ({ lang: htmlLang[t], href: new URL(paginas[sleutel][t], site.url).href }))
  : [];
// x-default wijst naar de Nederlandse versie: dat is de hoofdtaal van het merk.
const xDefault = sleutel ? new URL(paginas[sleutel][standaardTaal], site.url).href : '';

const ogLocale: Record<Taal, string> = { nl: 'nl_NL', en: 'en_GB', fr: 'fr_FR', ar: 'ar_MA' };

// Organization-schema staat op elke pagina (merk-autoriteit).
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  '@id': site.url + '/#organization',
  name: site.naam,
  legalName: `${site.naam} ${site.rechtsvorm}`,
  url: site.url,
  image: ogImageAbs,
  logo: new URL(site.logo, site.url).href,
  telephone: site.telefoon,
  email: site.email,
  description: site.tagline,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.adres,
    addressLocality: 'Rabat',
    addressRegion: 'Rabat-Salé-Kénitra',
    addressCountry: 'MA',
  },
  // Officiële Marokkaanse bedrijfsidentificatie (entity SEO / vertrouwen).
  taxID: site.ice,
  identifier: [
    { '@type': 'PropertyValue', name: 'RC', value: `${site.rc} (Rabat)` },
    { '@type': 'PropertyValue', name: 'ICE', value: site.ice },
  ],
  // Werkgebied is Marokko; de klantenkring is internationaal (met name Europa).
  areaServed: [
    { '@type': 'Country', name: 'Marokko' },
    { '@type': 'Place', name: 'Europa' },
  ],
  knowsLanguage: ['nl', 'ar', 'fr', 'en'],
  slogan: 'International real estate advisory in Morocco.',
  foundingDate: String(site.oprichting),
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: site.telefoon,
    email: site.email,
    contactType: 'customer service',
    areaServed: ['MA', 'NL', 'BE', 'FR', 'DE', 'ES'],
    availableLanguage: ['Dutch', 'English', 'French', 'Arabic'],
  },
  ...(site.sameAs.length ? { sameAs: site.sameAs } : {}),
};

const allSchema = [orgSchema, ...schema];
---

<!doctype html>
<html lang={htmlLang[taal]} dir={rtl ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="4E5n68Mls5WvxJv_v36tGQ2gZ6X7AT0wwAsrwAs4TVA" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    {/* hreflang — verbindt de vertalingen onderling. */}
    {alternates.map((a) => <link rel="alternate" hreflang={a.lang} href={a.href} />)}
    {xDefault && <link rel="alternate" hreflang="x-default" href={xDefault} />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.naam} />
    <meta property="og:locale" content={ogLocale[taal]} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    {/* Cormorant Garamond en Jost bevatten geen Arabisch schrift. Amiri is een
        klassieke naskh-letter die past bij de serif-koppen; Noto Sans Arabic
        dekt de lopende tekst. Alleen laden op Arabische pagina's. */}
    {rtl && (
      <link
        href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Noto+Sans+Arabic:wght@300;400;500&display=swap"
        rel="stylesheet"
      />
    )}

    {allSchema.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body class:list={[toonSticky && 'has-sticky-cta', rtl && 'rtl']}>
    <Nav taal={taal} sleutel={sleutel} />
    <main>
      <slot />
    </main>
    <Footer taal={taal} />
    {toonSticky && <StickyWhatsapp taal={taal} />}
  </body>
</html>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import Definitie from '../components/Definitie.astro';
import Faq from '../components/Faq.astro';
import LeadCta from '../components/LeadCta.astro';
import VerderLezen from '../components/VerderLezen.astro';
import { faqSchema, serviceSchema } from '../data/schema';

const path = '/nieuwbouw-vastgoed-marokko/';
const faqs = [
  { q: 'Wat betekent off-plan kopen in Marokko?', a: 'Off-plan (of “op plan”) betekent dat u koopt vóór of tijdens de bouw, op basis van tekeningen en specificaties. U betaalt vaak in termijnen naarmate de bouw vordert. Het voordeel is een lagere instapprijs; het nadeel is dat u koopt wat er nog niet staat.' },
  { q: 'Is nieuwbouw of off-plan kopen veilig?', a: 'Het kan veilig zijn, maar valt of staat met de ontwikkelaar en het contract. Wij controleren het track record van de ontwikkelaar, de grondtitel, de bouwvergunning en de contractvoorwaarden vóór u zich verbindt of iets aanbetaalt.' },
  { q: 'Kan ik een nieuwbouwappartement in termijnen betalen?', a: 'Ja, bij nieuwbouw is gespreide betaling tijdens de bouw gebruikelijk. Belangrijk is dat de termijnen gekoppeld zijn aan bouwfasen en dat uw betalingen in het contract beschermd zijn. Wij toetsen dit voor u.' },
  { q: 'Kan ik als buitenlandse koper financiering krijgen in Marokko?', a: 'Meerdere Marokkaanse banken bieden financiering aan niet-ingezetenen, met eigen voorwaarden per bank en profiel. Laat u hierover goed adviseren; wij denken met u mee over de mogelijkheden.' },
];
---
<BaseLayout
  title="Nieuwbouw & off-plan vastgoed in Marokko kopen | Maghreb Estates"
  description="Nieuwbouw en off-plan vastgoed in Marokko kopen: hoe betaling in termijnen werkt, welke documenten en risico’s spelen, en hoe wij de ontwikkelaar, het project en het contract controleren."
  path={path}
  schema={[faqSchema(faqs), serviceSchema({ naam: 'Nieuwbouw & off-plan vastgoed Marokko', beschrijving: 'Controle en begeleiding bij aankoop van nieuwbouw en off-plan vastgoed in Marokko, inclusief betaling in termijnen.', path })]}
>
  <Hero
    compact
    eyebrow="Nieuwbouw & off-plan"
    title="Nieuwbouw & off-plan in Marokko,<br /><em>eerst gecontroleerd</em>"
    sub="Kopen vóór de bouw af is: een lagere instapprijs en betaling in termijnen, maar met extra risico. Wij controleren het project, de ontwikkelaar en het contract vóór u zich verbindt."
    image="/images/villa3.jpg"
    ctas={[
      { label: 'Laat het project beoordelen', href: '/contact/?doel=aankoopcontrole', primary: true },
      { label: 'Plan adviesgesprek', href: '/contact/' },
    ]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Nieuwbouw & off-plan', href: path }]} />
  <AiBlocks path={path} />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <h2>Voor wie is dit?</h2>
      <p>Voor internationale kopers en investeerders die willen instappen vóór de waardestijging, of die gespreid willen betalen in plaats van de volledige koopsom ineens. Off-plan is aantrekkelijk — maar juist bij een project dat er nog niet staat, bepaalt de kwaliteit van de ontwikkelaar en het contract of het goed afloopt.</p>

      <Definitie id="off-plan" />

      <h2>Hoe werkt kopen in termijnen?</h2>
      <p>De koopsom wordt opgedeeld in termijnen, idealiter gekoppeld aan <strong>bouwfasen</strong> — fundering, ruwbouw, afbouw, oplevering — zodat u betaalt naarmate er daadwerkelijk gebouwd wordt. Dat verlaagt uw instapdrempel en houdt de prikkel bij de ontwikkelaar. Bij bestaande bouw is termijnbetaling ongebruikelijk.</p>

      <div class="warn">
        <strong>Termijnbetaling zonder waarborgen is riskant.</strong>
        <p>Betaal alleen als de ontwikkelaar betrouwbaar is, de grondtitel en vergunningen kloppen, en de termijnen aan bouwfasen zijn gekoppeld. Zorg dat uw betalingen in het contract beschermd zijn.</p>
      </div>

      <h2>Wat doen wij concreet?</h2>
      <p>Off-plan valt of staat met de ontwikkelaar en het contract. Wij controleren vier dingen vóór u zich verbindt:</p>
      <ul class="checks">
        <li><strong>Het project:</strong> plannen, bouwvergunning, realistische planning en beloofde kwaliteit.</li>
        <li><strong>De ontwikkelaar:</strong> track record, eerder opgeleverde projecten en financiële soliditeit.</li>
        <li><strong>Het contract:</strong> termijnen gekoppeld aan bouwfasen, ontbindende voorwaarden en bescherming van uw betalingen.</li>
        <li><strong>De betaling:</strong> uitsluitend via de notaris, correct gedocumenteerd, nooit informeel.</li>
      </ul>

      <h2>Nieuwbouw vs. bestaande bouw</h2>
      <div class="compare-wrap">
        <table class="compare">
          <caption>Vergelijking: nieuwbouw (off-plan) vs. bestaande bouw</caption>
          <thead>
            <tr><th>Aspect</th><th>Nieuwbouw / off-plan</th><th>Bestaande bouw</th></tr>
          </thead>
          <tbody>
            <tr><th>Prijs</th><td>Vaak lagere instapprijs</td><td>Marktprijs, direct beschikbaar</td></tr>
            <tr><th>Betaling</th><td>Vaak in termijnen tijdens de bouw</td><td>Doorgaans ineens bij overdracht</td></tr>
            <tr><th>Zekerheid</th><td>U koopt wat er nog niet staat</td><td>U ziet wat u koopt</td></tr>
            <tr><th>Grootste risico</th><td>Ontwikkelaar, vertraging, oplevering</td><td>Staat/onderhoud en titelstatus</td></tr>
            <tr><th>Controle vooraf</th><td>Ontwikkelaar, vergunning, contract</td><td>Eigendomstitel, bouwkundige staat</td></tr>
          </tbody>
        </table>
      </div>

      <h2>Wanneer moet u oppassen?</h2>
      <ul>
        <li>De ontwikkelaar heeft geen aantoonbaar track record of opgeleverde projecten.</li>
        <li>De grondtitel of bouwvergunning ontbreekt of is onduidelijk.</li>
        <li>Termijnen zijn niet aan bouwfasen gekoppeld, of u moet vooraf een groot bedrag storten.</li>
        <li>Er wordt druk gezet met een “speciale prijs” of een korte beslistermijn.</li>
        <li>Betaling wordt informeel of buiten de notaris om gevraagd.</li>
      </ul>

      <h2>Waarom Maghreb Estates?</h2>
      <p>Wij zijn onafhankelijk van ontwikkelaars en verdienen niets aan een specifiek project. Wij beoordelen de brochure op wat er onder ligt: papieren, vergunningen, track record en contractvoorwaarden. Onze klanten komen uit heel Europa; wij begeleiden hen in het Nederlands, Engels, Frans en Arabisch, en zijn ter plaatse aanwezig om het project te bekijken.</p>

      <p style="margin-top:36px"><a href="/contact/?doel=aankoopcontrole" class="btn btn--primary">Laat het project beoordelen</a></p>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over nieuwbouw & off-plan in Marokko" />

  <VerderLezen items={[
    { label: 'Aankoopbegeleiding', href: '/aankoopbegeleiding-vastgoed-marokko/', tekst: 'Het volledige traject van selectie tot overdracht.' },
    { label: 'Juridische documenten', href: '/juridische-documenten-vastgoed-marokko/', tekst: 'Welke papieren horen bij nieuwbouw en overdracht.' },
    { label: 'Investeringsadvies', href: '/investeren-vastgoed-marokko/', tekst: 'Wat off-plan betekent voor uw netto rendement.' },
    { label: 'Markten in Marokko', href: '/vastgoed-marokko/', tekst: 'Overzicht van de steden en regio’s waarin wij actief zijn.' },
  ]} />

  <LeadCta path={path} />
</BaseLayout>

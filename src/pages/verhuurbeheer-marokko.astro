---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import CtaInline from '../components/CtaInline.astro';
import Faq from '../components/Faq.astro';
import LeadCta from '../components/LeadCta.astro';
import { faqSchema, serviceSchema } from '../data/schema';

const path = '/verhuurbeheer-marokko/';
const faqs = [
  { q: 'Wat is verhuurbeheer in Marokko?', a: 'Verhuurbeheer richt zich op alles rondom de verhuur zelf: huurders vinden en screenen, huurcontracten opstellen, de huur innen en de administratie bijhouden. Het gaat om de commerciële en contractuele kant van uw woning.' },
  { q: 'Wat is het verschil met vastgoedbeheer?', a: 'Vastgoedbeheer is het bredere pakket (inclusief onderhoud en toezicht). Verhuurbeheer is specifiek de verhuurkant: huurders, contracten en huurinning. U kunt beide combineren of alleen verhuurbeheer afnemen.' },
  { q: 'Hoe worden huurders geselecteerd?', a: 'Wij screenen huurders lokaal en stellen correcte contracten op, zodat u het risico op wanbetaling en problemen beperkt. Dit is op afstand zelf lastig te regelen.' },
  { q: 'Wat kost verhuurbeheer?', a: 'Meestal een percentage van de huurinkomsten, zodat onze belangen gelijklopen: u betaalt bij resultaat. In een gesprek maken wij de tarieven transparant.' },
  { q: 'Krijg ik inzicht in mijn huurinkomsten?', a: 'Ja. U ontvangt heldere, periodieke rapportage over inkomsten en eventuele kosten, zodat u op afstand volledig zicht houdt.' },
];
---
<BaseLayout
  title="Verhuurbeheer Marokko: huurders, contracten & huurinning | Maghreb Estates"
  description="Verhuurbeheer in Marokko vanuit Nederland: huurders vinden en screenen, contracten opstellen en huur innen. Transparante rapportage en lokale controle, u betaalt bij resultaat."
  path={path}
  schema={[faqSchema(faqs), serviceSchema({ naam: 'Verhuurbeheer Marokko', beschrijving: 'Beheer van de verhuur van woningen in Marokko: huurders, contracten en huurinning.', path })]}
>
  <Hero
    compact
    eyebrow="Beheer"
    title="Verhuurbeheer in Marokko,<br /><em>huurders zonder zorgen</em>"
    sub="Huurders vinden en screenen, contracten opstellen en de huur innen — de verhuurkant van uw woning, professioneel geregeld op afstand."
    image="/images/villa1.jpg"
    ctas={[
      { label: 'Plan gratis adviesgesprek', href: '/contact/', primary: true },
      { label: 'Vraag rendementsindicatie aan', href: '/contact/?doel=investeringsanalyse' },
    ]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Vastgoedbeheer', href: '/vastgoedbeheer-marokko/' }, { label: 'Verhuurbeheer', href: path }]} />
  <AiBlocks path={path} />
  <TrustStrip />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <p><strong>Verhuurbeheer in Marokko</strong> richt zich op de commerciële en contractuele kant van uw woning: de juiste huurder vinden, een correct contract opstellen en de huur op tijd innen. Juist dit is vanuit Nederland lastig zelf te doen — een verkeerde huurder of een slecht contract kost u geld en gedoe.</p>

      <h2>Wat verhuurbeheer omvat</h2>
      <ul class="checks">
        <li><strong>Huurders vinden:</strong> gerichte werving voor uw woning en doelgroep.</li>
        <li><strong>Screening:</strong> huurders lokaal beoordelen om risico te beperken.</li>
        <li><strong>Contracten:</strong> correcte, duidelijke huurcontracten.</li>
        <li><strong>Huurinning:</strong> tijdige inning en heldere administratie.</li>
        <li><strong>Rapportage:</strong> periodiek inzicht in uw huurinkomsten.</li>
      </ul>

      <div class="warn">
        <strong>Een verkeerde huurder is duur.</strong>
        <p>Wanbetaling of een slecht contract is op afstand moeilijk op te lossen. Goede screening en correcte contracten vooraf voorkomen de meeste problemen.</p>
      </div>

      <CtaInline
        title="Uw woning zorgeloos verhuren?"
        text="Wij regelen de huurders, contracten en huurinning. Vraag een indicatie van uw huurinkomsten aan."
        label="Vraag rendementsindicatie aan"
        href="/contact/?doel=investeringsanalyse"
      />

      <h2>Verhuurbeheer of volledig beheer?</h2>
      <p>Wilt u naast de verhuur ook onderhoud en toezicht uit handen geven? Kies dan het bredere <a href="/vastgoedbeheer-marokko/">vastgoedbeheer</a> of specifiek <a href="/woningbeheer-marokko/">woningbeheer</a> voor de fysieke kant. Voor korte, toeristische verhuur kijkt u naar <a href="/airbnb-beheer-marokko/">Airbnb-beheer</a>.</p>

      <h2>Voor investeerders en eigenaren</h2>
      <p>Verhuurbeheer zorgt dat uw <a href="/huur-rendement-marokko/">huurrendement</a> daadwerkelijk binnenkomt. Wilt u eerst uw woning laten verhuren vanuit Nederland? Zie <a href="/huis-verhuren-marokko-vanuit-nederland/">huis verhuren vanuit Nederland</a>. Overweegt u nog aankoop, start dan bij <a href="/investeren-vastgoed-marokko/">investeren in vastgoed Marokko</a>.</p>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over verhuurbeheer" />
  <LeadCta path={path} />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Faq from '../components/Faq.astro';
import LeadCta from '../components/LeadCta.astro';
import VerderLezen from '../components/VerderLezen.astro';
import { steden } from '../data/steden';
import { faqSchema, serviceSchema } from '../data/schema';

const path = '/vastgoed-marokko/';

// Steden gegroepeerd per type markt (rustiger overzicht dan één lange lijst).
const stedenGroepen = [
  { titel: 'Noord-Marokko', slugs: ['tanger', 'tetouan', 'martil', 'mdiq', 'al-hoceima', 'nador'] },
  { titel: 'Grote steden & zakelijke markten', slugs: ['casablanca', 'rabat', 'kenitra', 'temara', 'skhirat'] },
  { titel: 'Toerisme & lifestyle', slugs: ['marrakech', 'agadir', 'essaouira', 'saidia', 'dakhla'] },
  { titel: 'Overige steden', slugs: ['oujda', 'fes'] },
].map((g) => ({ titel: g.titel, steden: g.slugs.map((slug) => steden.find((s) => s.slug === slug)!).filter(Boolean) }));

const faqs = [
  { q: 'Mag ik als buitenlandse koper vastgoed kopen in Marokko?', a: 'Ja. Buitenlandse kopers mogen vrijwel overal in Marokko onroerend goed kopen. Alleen bepaalde landbouwgrond (terres agricoles) is uitgezonderd. Voor woningen, appartementen en villa’s gelden geen nationaliteitsbeperkingen.' },
  { q: 'In welke steden kan ik het beste vastgoed kopen?', a: 'Dat hangt af van uw doel. Voor rendement en zakelijke verhuur zijn Tanger, Casablanca en Rabat sterk; voor toeristische verhuur kijkt u naar Marrakech, Agadir en de kuststeden; voor vroege groeikansen naar Kenitra, Nador en Dakhla.' },
  { q: 'Wat kost vastgoed kopen in Marokko naast de koopsom?', a: 'Reken op circa 6 tot 10% bijkomende kosten: registratierechten, notariskosten en kadaster. Wij maken vooraf een transparante berekening voor uw situatie.' },
  { q: 'Kan ik vastgoed kopen zonder er zelf te zijn?', a: 'Ja, volledig op afstand met een volmacht (procuration). Wij regelen bezichtiging, dossiercontrole en de gang naar de notaris.' },
];
---
<BaseLayout
  title="Markten in Marokko: vastgoed per stad | Maghreb Estates"
  description="De Marokkaanse vastgoedmarkt per stad en regio, voor internationale kopers en investeerders. Van Tanger en Casablanca tot Marrakech, Agadir en Dakhla."
  path={path}
  schema={[faqSchema(faqs), serviceSchema({ naam: 'Vastgoed Marokko begeleiding', beschrijving: 'Begeleiding bij kopen, investeren, verhuren en beheren van vastgoed in Marokko voor internationale kopers.', path })]}
>
  <Hero
    compact
    eyebrow="Markten in Marokko"
    title="De Marokkaanse markt,<br /><em>stad voor stad</em>"
    sub="Elke stad kent een eigen prijsniveau, vraag en verhuurpotentie. Een overzicht van de markten waarin wij actief zijn, voor internationale kopers en investeerders."
    image="/images/villa4.jpg"
    ctas={[
      { label: 'Plan adviesgesprek', href: '/contact/', primary: true },
      { label: 'Laat een object beoordelen', href: '/contact/?doel=aankoopcontrole' },
    ]}
  />
  <Breadcrumbs items={[{ label: 'Markten in Marokko', href: path }]} />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <p><strong>De Marokkaanse vastgoedmarkt is geen één markt.</strong> Het noorden — Tanger, Nador, Al Hoceima, Tetouan en de kustplaatsen — is sterk verbonden met de diaspora en profiteert van de havenontwikkeling. De economische as Casablanca–Rabat–Kenitra biedt stabiliteit, zakelijke verhuur en gestage waardegroei. Marrakech, Agadir en de kuststeden draaien op toerisme, met hogere maar seizoensgevoelige rendementen.</p>
      <p>Welke markt bij u past, hangt af van uw doel: eigen gebruik, langetermijnverhuur of waardegroei. Wij beoordelen elk object binnen de context van zijn eigen stad en wijk — een goede prijs in Tanger betekent iets anders dan een goede prijs in Essaouira.</p>

      <div class="warn">
        <strong>Marktcijfers zijn een startpunt, geen oordeel over één woning.</strong>
        <p>Prijsindicaties per stad zeggen weinig over een specifiek object. Straat, staat, bouwjaar, papieren en verhuurbaarheid bepalen de werkelijke waarde. Laat een concreet object altijd afzonderlijk beoordelen.</p>
      </div>
    </div>
  </section>

  <section class="section section--tinted" id="steden">
    <div class="container">
      <div class="section__header section__header--center">
        <p class="eyebrow">Alle markten</p>
        <h2>Vastgoed per <em>stad in Marokko</em></h2>
        <p class="section__desc">Gegroepeerd per type markt. Kies uw stad voor gerichte informatie over prijzen, vraag en verhuurpotentie.</p>
      </div>
      {stedenGroepen.map((g) => (
        <div class="steden-groep">
          <h3 class="steden-groep__titel">{g.titel}</h3>
          <div class="steden">
            {g.steden.map((s) => (
              <a class="stad-chip" href={`/vastgoed-${s.slug}/`}>
                <strong>{s.naam}</strong>
                <span>{s.regio}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over vastgoed in Marokko" />

  <VerderLezen items={[
    { label: 'Aankoopbegeleiding', href: '/aankoopbegeleiding-vastgoed-marokko/', tekst: 'Selectie, due diligence en begeleiding tot de overdracht.' },
    { label: 'Investeringsadvies', href: '/investeren-vastgoed-marokko/', tekst: 'Netto rendement en strategie per stad en objecttype.' },
    { label: 'Steden & markt vergelijken', href: '/beste-stad-investeren-vastgoed-marokko/', tekst: 'Welke stad past bij welke investeringsstrategie.' },
    { label: 'Kennisbank', href: '/kennisbank/', tekst: 'Kosten, risico’s, juridische documenten en begrippen.' },
  ]} />

  <LeadCta path={path} />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import Definitie from '../components/Definitie.astro';
import CtaInline from '../components/CtaInline.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';
import { faqSchema, articleSchema } from '../data/schema';

const path = '/off-plan-vastgoed-marokko/';
const faqs = [
  { q: 'Wat betekent off-plan kopen in Marokko?', a: 'Off-plan (of “op plan”) betekent dat u koopt vóór of tijdens de bouw, op basis van tekeningen en specificaties. U betaalt vaak in termijnen naarmate de bouw vordert. Het voordeel is een lagere instapprijs; het nadeel is dat u koopt wat er nog niet staat.' },
  { q: 'Wat zijn de voordelen van off-plan?', a: 'Meestal een lagere prijs dan opgeleverd vastgoed, betaling in termijnen, keuze in afwerking, en potentiële waardestijging tot aan oplevering. Voor investeerders kan vroeg instappen aantrekkelijk zijn.' },
  { q: 'Wat zijn de risico’s van off-plan kopen?', a: 'Vertraging of niet-oplevering, afwijkende kwaliteit, een onbetrouwbare ontwikkelaar, en betalingen die niet goed beschermd zijn. Daarom is controle van de ontwikkelaar, de grondtitel en het contract essentieel.' },
  { q: 'Hoe bescherm ik mijn betalingen bij off-plan?', a: 'Zorg dat de termijnen gekoppeld zijn aan bouwfasen, dat de grondtitel en vergunningen kloppen, en dat het contract u beschermt. Wij toetsen dit vóór u zich verbindt.' },
  { q: 'Controleren jullie de projectontwikkelaar?', a: 'Ja. Wij beoordelen het track record, eerder opgeleverde projecten, de papieren en de contractvoorwaarden, zodat u weet of de belofte realistisch is.' },
];
---
<BaseLayout
  title="Off-plan vastgoed Marokko: voordelen, risico’s & controle | Maghreb Estates"
  description="Off-plan vastgoed kopen in Marokko? Ontdek de voordelen (lagere prijs, betaling in termijnen) én de risico’s, en hoe u de ontwikkelaar en het contract laat controleren vóór u instapt."
  path={path}
  schema={[faqSchema(faqs), articleSchema({ titel: 'Off-plan vastgoed Marokko', beschrijving: 'Voordelen, risico’s en controle bij off-plan vastgoed kopen in Marokko.', path })]}
>
  <Hero
    compact
    eyebrow="Investeren"
    title="Off-plan vastgoed<br /><em>kopen in Marokko</em>"
    sub="Kopen vóór de bouw af is: een lagere prijs en betaling in termijnen, maar met extra risico. Hoe u de kans benut én uzelf beschermt."
    image="/images/villa3.jpg"
    ctas={[
      { label: 'Laat het project controleren', href: '/contact/?doel=aankoopcontrole', primary: true },
      { label: 'Plan gratis adviesgesprek', href: '/contact/' },
    ]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Investeren', href: '/investeren-vastgoed-marokko/' }, { label: 'Off-plan vastgoed', href: path }]} />
  <AiBlocks path={path} />
  <TrustStrip />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <p><strong>Off-plan vastgoed in Marokko</strong> — kopen vóór of tijdens de bouw — is populair omdat u vaak onder de marktprijs instapt en in termijnen betaalt. Voor investeerders kan dat aantrekkelijk zijn: instappen vóór de waardestijging. Maar u koopt wat er nog niet staat, en dat vraagt om extra zorgvuldigheid.</p>

      <Definitie id="off-plan" />

      <h2>De voordelen</h2>
      <ul class="checks">
        <li>Doorgaans een lagere prijs dan opgeleverd vastgoed.</li>
        <li>Betaling gespreid in termijnen tijdens de bouw.</li>
        <li>Vaak keuze in indeling en afwerking.</li>
        <li>Potentiële waardestijging tot aan de oplevering.</li>
      </ul>

      <h2>De risico’s</h2>
      <ul>
        <li>Vertraging of, in het ergste geval, niet-oplevering.</li>
        <li>Afwijkende kwaliteit of afwerking t.o.v. de belofte.</li>
        <li>Een onbetrouwbare of financieel zwakke ontwikkelaar.</li>
        <li>Termijnbetalingen die onvoldoende beschermd zijn.</li>
      </ul>

      <div class="warn">
        <strong>Off-plan valt of staat met de ontwikkelaar en het contract.</strong>
        <p>Betaal nooit termijnen zonder dat de grondtitel (<a href="/titre-foncier-marokko/">titre foncier</a>), de bouwvergunning en de contractvoorwaarden zijn gecontroleerd. Zorg dat betalingen aan bouwfasen gekoppeld zijn.</p>
      </div>

      <CtaInline
        title="Overweegt u een off-plan project?"
        text="Stuur ons de brochure of de ontwikkelaar. Wij beoordelen of het klopt vóór u een euro overmaakt."
        label="Laat het project controleren"
        href="/contact/?doel=aankoopcontrole"
      />

      <h2>Zo koopt u off-plan veilig</h2>
      <p>Onze aanpak sluit aan op onze <a href="/nieuwbouwprojecten-marokko/">controle van nieuwbouwprojecten</a>: verificatie van de ontwikkelaar, papieren en contract. Combineer dit met onze <a href="/aankoopbegeleiding-vastgoed-marokko/">aankoopbegeleiding</a> en let op de bredere <a href="/risicos-huis-kopen-marokko/">risico’s</a> en het voorkomen van <a href="/oplichting-vastgoed-marokko-voorkomen/">oplichting</a>.</p>

      <h2>Off-plan als investering</h2>
      <p>Voor investeerders kan off-plan renderen via waardestijging én verhuur na oplevering. Bekijk het verwachte <a href="/huur-rendement-marokko/">huurrendement</a>, de <a href="/beste-stad-investeren-vastgoed-marokko/">beste steden</a> en de mogelijkheid om <a href="/appartement-marokko-kopen-in-termijnen/">een appartement in termijnen te kopen</a>.</p>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over off-plan vastgoed" />
  <CtaBand label="Laat het project controleren" title="Off-plan overwegen?" text="Wij controleren de ontwikkelaar, de papieren en het contract vóór u zich verbindt." href="/contact/?doel=aankoopcontrole" />
</BaseLayout>

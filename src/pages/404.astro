---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Pagina niet gevonden (404) | Maghreb Estates" description="Deze pagina bestaat niet of is verplaatst." noindex>
  <section class="section" style="text-align:center;min-height:52vh;display:flex;align-items:center">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1 style="margin-bottom:16px">Deze pagina bestaat niet</h1>
      <p style="color:var(--text-muted);margin:0 auto 28px">De pagina is verplaatst of bestaat niet meer. Ga terug naar de homepage of bekijk vastgoed per stad.</p>
      <a href="/" class="btn btn--primary">Naar de homepage</a>
      <a href="/vastgoed-marokko/" class="btn btn--outline" style="margin-left:10px">Vastgoed Marokko</a>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import Faq from '../components/Faq.astro';
import LeadCta from '../components/LeadCta.astro';
import { faqSchema, serviceSchema } from '../data/schema';

const path = '/huis-verhuren-marokko-vanuit-nederland/';
const faqs = [
  { q: 'Kan ik mijn huis in Marokko verhuren vanuit Nederland?', a: 'Ja. Wij verzorgen de volledige verhuur op afstand: huurders vinden en screenen, contracten opstellen, huur innen en onderhoud regelen. U houdt zicht via periodieke rapportage.' },
  { q: 'Hoe vind ik betrouwbare huurders in Marokko?', a: 'Wij screenen huurders lokaal en stellen correcte huurcontracten op. Zo beperkt u het risico op wanbetaling of problemen — iets wat op afstand zelf regelen lastig is.' },
  { q: 'Wat kost verhuurbeheer in Marokko?', a: 'Beheerkosten worden meestal berekend als een percentage van de huurinkomsten. U betaalt dus alleen bij resultaat. In een gesprek maken we de tarieven en diensten transparant.' },
];
---
<BaseLayout
  title="Huis verhuren in Marokko vanuit Nederland | Maghreb Estates"
  description="Uw huis verhuren in Marokko vanuit Nederland? Wij regelen huurders, contracten, huurinning en onderhoud. Verhuurbeheer op afstand met volledige transparantie."
  path={path}
  schema={[faqSchema(faqs), serviceSchema({ naam: 'Huis verhuren Marokko', beschrijving: 'Verhuurbeheer van woningen in Marokko voor eigenaren in Nederland.', path })]}
>
  <Hero
    compact
    eyebrow="Verhuren"
    title="Uw huis verhuren in Marokko,<br /><em>zonder zorgen op afstand</em>"
    sub="Huurders, contracten, huurinning en onderhoud — wij nemen de verhuur volledig uit handen terwijl u in Nederland bent."
    image="/images/villa1.jpg"
    ctas={[{ label: 'Plan gratis adviesgesprek', href: '/contact/', primary: true }]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Vastgoedbeheer', href: '/vastgoedbeheer-marokko/' }, { label: 'Huis verhuren', href: path }]} />
  <AiBlocks path={path} />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <p>Uw <strong>huis verhuren in Marokko vanuit Nederland</strong> klinkt ingewikkeld, maar met lokale aanwezigheid is het goed te regelen. Wij zorgen dat uw woning rendeert en in goede staat blijft, zonder dat u er zelf voor hoeft te zijn.</p>

      <h2>Wat wij regelen</h2>
      <ul>
        <li><strong>Huurders vinden & screenen:</strong> lokaal, met correcte contracten.</li>
        <li><strong>Huurinning:</strong> tijdige inning en heldere administratie.</li>
        <li><strong>Onderhoud & toezicht:</strong> reparaties en periodieke controle.</li>
        <li><strong>Rapportage:</strong> u houdt op afstand zicht op inkomsten en staat van de woning.</li>
      </ul>

      <h2>Langetermijn of toeristisch?</h2>
      <p>Wilt u juist kort en toeristisch verhuren voor hoger rendement? Bekijk dan <a href="/airbnb-beheer-marokko/">Airbnb-beheer in Marokko</a>. Voor het complete plaatje ziet u <a href="/vastgoedbeheer-marokko/">vastgoedbeheer</a>.</p>

      <h2>Verhuur als onderdeel van uw rendement</h2>
      <p>Verhuur is de motor achter uw <a href="/rendement-vastgoed-marokko/">rendement</a>. Overweegt u nog aankoop? Start bij <a href="/investeren-vastgoed-marokko/">investeren in vastgoed Marokko</a> en onze <a href="/aankoopbegeleiding-vastgoed-marokko/">aankoopbegeleiding</a>.</p>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over verhuren in Marokko" />
  <LeadCta path={path} />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import Faq from '../components/Faq.astro';
import LeadCta from '../components/LeadCta.astro';
import VerderLezen from '../components/VerderLezen.astro';
import { faqSchema, articleSchema } from '../data/schema';

const path = '/risicos-huis-kopen-marokko/';
// URL blijft ongewijzigd voor SEO-behoud; de pagina heet en leest nu als
// "aandachtspunten". Bewust niet prominent in menu, footer of homepage.
const faqs = [
  { q: 'Welke aandachtspunten spelen bij vastgoed kopen in Marokko?', a: 'De belangrijkste aandachtspunten zijn de eigendomsinformatie (een geregistreerde titre foncier), de contractvoorwaarden, de betalingsroute, de marktwaarde en de overdracht bij de notaris. Bij nieuwbouw komt de beoordeling van de ontwikkelaar en de planning erbij.' },
  { q: 'Hoe beoordeel je of een dossier compleet is?', a: 'Een compleet dossier bevat de geregistreerde eigendomstitel, informatie over eventuele hypotheken of beslagen, het koopcontract met heldere voorwaarden, en duidelijkheid over de bevoegdheid van de verkoper. Wij beoordelen deze onderdelen vóór de overdracht.' },
  { q: 'Waarom verloopt de betaling via de notaris?', a: 'De notaris legt de betalingsmodaliteiten vast in de akte en verzorgt de inschrijving bij het kadaster. Daarmee is de route controleerbaar en de overdracht juridisch sluitend.' },
];
---
<BaseLayout
  title="Aandachtspunten bij vastgoed kopen in Marokko | Maghreb Estates"
  description="Documentcontrole, betalingsroute, contractvoorwaarden, marktwaarde en overdracht: de aandachtspunten bij het kopen van vastgoed in Marokko en hoe wij ze beoordelen."
  path={path}
  schema={[faqSchema(faqs), articleSchema({ titel: 'Aandachtspunten bij vastgoed kopen in Marokko', beschrijving: 'De belangrijkste aandachtspunten bij vastgoed kopen in Marokko en hoe ze worden beoordeeld.', path })]}
>
  <Hero
    image="/images/villa3.jpg"
    compact
    eyebrow="Aandachtspunten"
    title="Aandachtspunten bij vastgoed<br /><em>kopen in Marokko</em>"
    sub="Elke vastgoedmarkt heeft eigen juridische, commerciële en praktische aandachtspunten. Dit zijn de onderdelen die in een Marokkaans dossier aandacht vragen."
    ctas={[{ label: 'Laat een object analyseren', href: '/contact/?doel=objectanalyse', primary: true }]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Aandachtspunten', href: path }]} />
  <AiBlocks path={path} />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <p>Elke vastgoedmarkt heeft eigen juridische, commerciële en praktische aandachtspunten. In Marokko is het belangrijk om documenten, eigendom, prijs en betalingsroute zorgvuldig te beoordelen. De markt is lokaal en informatie is versnipperd, waardoor een gestructureerde beoordeling van het dossier meerwaarde heeft.</p>

      <h2>De belangrijkste aandachtspunten</h2>
      <ul>
        <li><strong>Documentcontrole:</strong> is er een geregistreerde <a href="/titre-foncier-marokko/">titre foncier</a> en zijn de bijbehorende stukken compleet?</li>
        <li><strong>Eigendom en bevoegdheid:</strong> is de verkoper juridisch bevoegd om te verkopen en zijn er mede-eigenaren?</li>
        <li><strong>Contractvoorwaarden:</strong> staan de aanbetaling, de termijnen en de ontbindende voorwaarden helder in het compromis de vente?</li>
        <li><strong>Betalingsroute:</strong> zijn de betaalmodaliteiten correct vastgelegd in de akte en verloopt de betaling via de notaris?</li>
        <li><strong>Marktwaarde:</strong> is de vraagprijs vergeleken met referentieobjecten en lokale prijsniveaus?</li>
        <li><strong>Overdracht:</strong> is de inschrijving bij het kadaster op uw naam geregeld?</li>
      </ul>

      <h2>Bij nieuwbouw en off-plan</h2>
      <p>Bij een project dat nog gebouwd moet worden, verschuift de beoordeling naar de ontwikkelaar en het contract: het track record, de bouwvergunning, de planning, de betalingsstructuur en de afspraken over oplevering. Dit staat uitgewerkt bij <a href="/nieuwbouw-vastgoed-marokko/">nieuwbouw &amp; off-plan</a>.</p>

      <h2>Hoe wij deze punten beoordelen</h2>
      <p>Onze aankoopbegeleiding is op deze onderdelen ingericht: documentcontrole, marktvergelijking, beoordeling van de contractvoorwaarden en lokale opvolging tot en met de overdracht bij de notaris. U ontvangt de bevindingen in één overzicht, zodat u de beslissing kunt onderbouwen.</p>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over de aandachtspunten" />

  <VerderLezen items={[
    { label: 'Juridische documenten', href: '/juridische-documenten-vastgoed-marokko/', tekst: 'Welke papieren horen bij een correcte overdracht in Marokko.' },
    { label: 'Aankoopbegeleiding', href: '/aankoopbegeleiding-vastgoed-marokko/', tekst: 'Het volledige traject van analyse tot overdracht.' },
    { label: 'De notaris', href: '/notaris-marokko-vastgoed/', tekst: 'De rol van de notaris bij de akte en de registratie.' },
    { label: 'Kosten bij aankoop', href: '/kosten-huis-kopen-marokko/', tekst: 'Wat u naast de koopsom betaalt.' },
  ]} />

  <LeadCta path={path} />
</BaseLayout>

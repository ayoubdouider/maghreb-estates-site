---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import Faq from '../components/Faq.astro';
import LeadCta from '../components/LeadCta.astro';
import VerderLezen from '../components/VerderLezen.astro';
import { faqSchema } from '../data/schema';

const path = '/vastgoedbeheer-marokko/';
// Beheer & verhuur is nog geen operationele kernservice. Deze pagina blijft
// indexeerbaar voor SEO, maar staat bewust niet in het hoofdmenu, niet in de
// footer, niet op de homepage en niet in prominente CTA's. De toon is
// terughoudend: meedenken op aanvraag, geen beloftes over uitvoering.
const faqs = [
  { q: 'Verzorgen jullie beheer van vastgoed in Marokko?', a: 'Wij kunnen op aanvraag meedenken over beheer, lokale opvolging of verhuurstructuur. Beschikbaarheid verschilt per stad, wijk en objecttype. Tijdens een adviesgesprek bespreken wij wat in uw situatie mogelijk is.' },
  { q: 'Wat komt er bij beheer op afstand kijken?', a: 'Doorgaans gaat het om lokale opvolging, toezicht op de woning, afstemming over onderhoud en — waar van toepassing — de verhuurstructuur en de administratie daaromheen. Welke onderdelen zinvol zijn, hangt af van het object en het gebruik.' },
  { q: 'Waar moet ik op letten bij een beheerafspraak?', a: 'Leg vooraf schriftelijk vast welke diensten worden geleverd, met welke frequentie, welke kosten daarbij horen en hoe er wordt gerapporteerd. Duidelijke afspraken voorkomen discussie achteraf.' },
];
---
<BaseLayout
  title="Vastgoedbeheer in Marokko: wat komt erbij kijken | Maghreb Estates"
  description="Beheer en verhuur van vastgoed in Marokko voor eigenaren buiten Marokko: welke onderdelen erbij komen kijken en waar de aandachtspunten liggen."
  path={path}
  schema={[faqSchema(faqs)]}
>
  <Hero
    image="/images/villa5.jpg"
    compact
    eyebrow="Beheer & verhuur"
    title="Vastgoedbeheer<br /><em>in Marokko</em>"
    sub="Wat komt er kijken bij het beheren of verhuren van een woning in Marokko wanneer u er zelf niet bent — en waar liggen de aandachtspunten?"
    ctas={[{ label: 'Plan adviesgesprek', href: '/adviesgesprek/', primary: true }]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Vastgoedbeheer', href: path }]} />
  <AiBlocks path={path} />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <div class="warn">
        <strong>Deze service is beschikbaar op aanvraag.</strong>
        <p>Wij kunnen op aanvraag meedenken over beheer, lokale opvolging of verhuurstructuur. Beschikbaarheid verschilt per stad, wijk en objecttype.</p>
      </div>

      <h2>Voor wie is dit relevant?</h2>
      <p>Voor eigenaren buiten Marokko: investeerders die hun woning willen laten renderen, en bezitters van een tweede woning die willen dat het huis in goede staat blijft. Beheer op afstand vraagt om duidelijke afspraken en een lokaal aanspreekpunt.</p>

      <h2>Welke onderdelen komen erbij kijken?</h2>
      <ul class="checks">
        <li><strong>Lokale opvolging:</strong> een aanspreekpunt ter plaatse voor praktische zaken rond de woning.</li>
        <li><strong>Toezicht:</strong> periodieke controle van de staat van het pand en het signaleren van onderhoud.</li>
        <li><strong>Onderhoudsafstemming:</strong> het aansturen en coördineren van reparaties en werkzaamheden.</li>
        <li><strong>Verhuurstructuur:</strong> de vorm van verhuur, de contractafspraken en de administratie daaromheen.</li>
        <li><strong>Rapportage:</strong> afspraken over wat er wordt teruggekoppeld en met welke frequentie.</li>
      </ul>

      <h2>Waar liggen de aandachtspunten?</h2>
      <p>De praktische haalbaarheid verschilt sterk per stad, wijk en objecttype. Bepaalde vormen van verhuur zijn in de ene stad goed te organiseren en in de andere nauwelijks. Leg daarom vooraf schriftelijk vast welke diensten worden geleverd, met welke frequentie, welke kosten daarbij horen en hoe er wordt gerapporteerd.</p>

      <h2>Wat kunnen wij betekenen?</h2>
      <p>Wij kunnen op aanvraag meedenken over beheer, lokale opvolging of verhuurstructuur. Tijdens een adviesgesprek bespreken wij uw object, uw doel en wat in uw stad en situatie realistisch mogelijk is. Zo weet u vooraf waar u aan toe bent, in plaats van achteraf.</p>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over vastgoedbeheer in Marokko" />

  <VerderLezen items={[
    { label: 'Investeringsadvies', href: '/investeren-vastgoed-marokko/', tekst: 'Bruto huurpotentie, netto resultaat en risicoprofiel naast elkaar.' },
    { label: 'Verkoopbegeleiding', href: '/huis-verkopen-marokko-vanuit-nederland/', tekst: 'Wanneer verkopen aantrekkelijker is dan aanhouden.' },
    { label: 'Waarde bepalen', href: '/waarde-woning-marokko-bepalen/', tekst: 'Hoe de marktwaarde van een woning in Marokko wordt bepaald.' },
    { label: 'Markten in Marokko', href: '/vastgoed-marokko/', tekst: 'Overzicht van de steden en regio’s waarin wij actief zijn.' },
  ]} />

  <LeadCta path={path} />
</BaseLayout>

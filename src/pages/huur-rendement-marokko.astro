---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import CtaInline from '../components/CtaInline.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';
import MarketDisclaimer from '../components/MarketDisclaimer.astro';
import { faqSchema, articleSchema } from '../data/schema';

const path = '/huur-rendement-marokko/';
const faqs = [
  { q: 'Wat is een realistisch huurrendement in Marokko?', a: 'Bij langetermijnverhuur zijn bruto huurrendementen van circa 5 tot 8% haalbaar, afhankelijk van stad, wijk en type. Bij toeristische verhuur kan het bruto rendement hoger liggen, maar met meer kosten en seizoensinvloed. Netto ligt het altijd lager.' },
  { q: 'Hoe bereken ik het huurrendement?', a: 'Brutorendement = jaarlijkse huurinkomsten gedeeld door de totale aankoopprijs (inclusief kosten), maal 100%. Voor het nettorendement trekt u beheer, onderhoud, belasting, verzekering en leegstand af. Wij rekenen altijd netto.' },
  { q: 'Welke kosten drukken op het huurrendement?', a: 'Beheer- en verhuurkosten, onderhoud, lokale belastingen, servicekosten (syndic), verzekering en leegstand tussen huurders. Deze bepalen het verschil tussen bruto en netto en moeten realistisch worden meegenomen.' },
  { q: 'Waar is het huurrendement het hoogst?', a: 'Dat verschilt per stad en verhuurvorm. Toeristische steden kunnen hogere bruto rendementen geven bij vakantieverhuur; grote steden bieden stabiele langetermijnverhuur. Bekijk de beste steden om te investeren voor de profielen.' },
  { q: 'Maken jullie een rendementsberekening voor mij?', a: 'Ja. Wij stellen een realistische, netto huurrendementsberekening op voor een specifiek object of stad, inclusief kosten en leegstand.' },
];
---
<BaseLayout
  title="Huurrendement Marokko: huurinkomsten realistisch berekenen | Maghreb Estates"
  description="Wat is het huurrendement van vastgoed in Marokko? Bruto vs netto, welke kosten meetellen en hoe u huurinkomsten realistisch berekent. Vraag een concrete rendementsberekening aan."
  path={path}
  schema={[faqSchema(faqs), articleSchema({ titel: 'Huurrendement Marokko', beschrijving: 'Hoe u het huurrendement van vastgoed in Marokko realistisch berekent.', path })]}
>
  <Hero
    compact
    eyebrow="Investeren"
    title="Huurrendement in Marokko,<br /><em>eerlijk doorgerekend</em>"
    sub="Van bruto naar netto: welke kosten meetellen en wat u realistisch aan huurinkomsten kunt verwachten — zonder opgeklopte percentages."
    image="/images/villa2.jpg"
    ctas={[
      { label: 'Vraag investeringsanalyse aan', href: '/contact/?doel=investeringsanalyse', primary: true },
      { label: 'Plan gratis adviesgesprek', href: '/contact/' },
    ]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Investeren', href: '/investeren-vastgoed-marokko/' }, { label: 'Huurrendement', href: path }]} />
  <AiBlocks path={path} />
  <TrustStrip />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <p>Het <strong>huurrendement van vastgoed in Marokko</strong> is voor veel investeerders de kern van de beslissing. Maar een percentage in een advertentie zegt weinig: het draait om het <strong>netto</strong> rendement, na alle kosten. Op deze pagina leest u hoe u het eerlijk berekent en wat realistisch is.</p>

      <h2>Bruto versus netto huurrendement</h2>
      <p>Het <strong>brutorendement</strong> is de jaarlijkse huur gedeeld door de totale aankoopprijs (inclusief <a href="/kosten-huis-kopen-marokko/">kosten</a>). Het <strong>nettorendement</strong> houdt rekening met de werkelijke lasten. Marktdata wijst landelijk op een <strong>gemiddeld bruto huurrendement van ±6,7–7,3%</strong> (2025–begin 2026); als werkband houden wij <strong>±6–8% bruto</strong> aan bij langetermijnverhuur. Reken vervolgens op een afslag van <strong>±20–35%</strong> naar netto.</p>

      <h2>Welke kosten trekt u af?</h2>
      <ul class="checks">
        <li>Beheer- en <a href="/verhuurbeheer-marokko/">verhuurbeheerkosten</a>.</li>
        <li>Onderhoud en reparaties.</li>
        <li>Lokale belastingen en <a href="/verborgen-kosten-huis-kopen-marokko/">terugkerende kosten</a>.</li>
        <li>Servicekosten (syndic) en verzekering.</li>
        <li>Leegstand tussen huurders.</li>
      </ul>

      <div class="warn">
        <strong>Pas op met “gegarandeerd rendement”.</strong>
        <p>Beloftes van gegarandeerde huur of vaste hoge rendementen verdienen kritische toetsing. Vraag altijd naar de onderbouwing en reken zelf (netto) na. Wij helpen u dat objectief te doen.</p>
      </div>

      <CtaInline
        title="Wilt u een netto rendementsberekening?"
        text="Wij rekenen een specifiek object of stad voor u door — inclusief kosten, leegstand en een realistische bezetting."
        label="Vraag investeringsanalyse aan"
        href="/contact/?doel=investeringsanalyse"
      />

      <h2>Langetermijn versus toeristische verhuur</h2>
      <div class="compare-wrap">
        <table class="compare">
          <caption>Vergelijking: langetermijnverhuur vs. Airbnb/korte termijn</caption>
          <thead>
            <tr><th>Aspect</th><th>Langetermijnverhuur</th><th>Airbnb / korte termijn</th></tr>
          </thead>
          <tbody>
            <tr><th>Bruto rendement</th><td>Stabiel, ±6–8% (indicatief)</td><td>Potentieel hoger, wisselend</td></tr>
            <tr><th>Bezetting</th><td>Doorgaans hoog en constant</td><td>Seizoensgevoelig (indicatief 38–47% in topsteden)</td></tr>
            <tr><th>Beheerintensiteit</th><td>Laag tot gemiddeld</td><td>Hoog (gasten, schoonmaak, prijzen)</td></tr>
            <tr><th>Kosten</th><td>Minder frequent</td><td>Schoonmaak, platform, meer onderhoud</td></tr>
            <tr><th>Geschikt in</th><td>Woonsteden (Casa, Rabat, Tanger)</td><td>Toeristische steden (Marrakech, Agadir, kust)</td></tr>
          </tbody>
        </table>
      </div>
      <p>Langetermijnverhuur geeft stabiliteit; <a href="/airbnb-marokko-investering/">toeristische verhuur (Airbnb)</a> kan hoger renderen maar is seizoens- en beheerintensiever. De beste vorm hangt af van stad en object — bekijk <a href="/beste-stad-investeren-vastgoed-marokko/">de beste steden om te investeren</a>.</p>

      <MarketDisclaimer />

      <h2>Rendement veiligstellen</h2>
      <p>Een berekend rendement is pas echt als het beheer klopt. Ons <a href="/vastgoedbeheer-marokko/">vastgoedbeheer</a> zorgt dat de huur binnenkomt en de woning in stand blijft. Zie ook de bredere aanpak op <a href="/investeren-vastgoed-marokko/">investeren in vastgoed Marokko</a> en het <a href="/rendement-vastgoed-marokko/">totale rendement</a> (huur + waardegroei).</p>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over huurrendement" />
  <CtaBand label="Vraag investeringsanalyse aan" title="Benieuwd naar uw huurrendement?" text="Wij maken een realistische, netto berekening voor uw object of stad." href="/contact/?doel=investeringsanalyse" />
</BaseLayout>

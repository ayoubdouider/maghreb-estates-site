---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import Faq from '../components/Faq.astro';
import LeadCta from '../components/LeadCta.astro';
import VerderLezen from '../components/VerderLezen.astro';
import { faqSchema, serviceSchema } from '../data/schema';

const path = '/investeren-vastgoed-marokko/';
const faqs = [
  { q: 'Is investeren in vastgoed in Marokko rendabel?', a: 'Ja, mits u de juiste stad, wijk en woning kiest. Bruto huurrendementen van 5 tot 8% zijn haalbaar bij langetermijnverhuur; in toeristische steden ligt dat bij vakantieverhuur hoger. Waardegroei in groeisteden komt daar bovenop.' },
  { q: 'Wat is een realistisch rendement, bruto en netto?', a: 'Een brutorendement (jaarhuur gedeeld door aankoopprijs) zegt weinig. Pas na aftrek van beheer, onderhoud, belasting, verzekering en leegstand ziet u het nettorendement. Wij rekenen altijd met netto, zodat u een eerlijk beeld krijgt.' },
  { q: 'Waar is de waardegroei het sterkst?', a: 'In groeisteden met grote infrastructuurinvesteringen: Tanger (haven Tanger Med), Kenitra (auto-industrie) en Dakhla (zuidelijke ontwikkeling). Vroeg instappen verhoogt uw rendement, maar vraagt om goede timing en controle.' },
  { q: 'Hoe beperk ik de risico’s van een vastgoedinvestering?', a: 'Elke investering start met dossiercontrole: verificatie van de eigendomstitel, kadaster en contract, en alles officieel via de notaris. Bij nieuwbouw controleren wij bovendien de projectontwikkelaar.' },
];
---
<BaseLayout
  title="Investeren in vastgoed Marokko: rendement & strategie | Maghreb Estates"
  description="Investeren in vastgoed in Marokko met rendement en zekerheid. Data-gedreven advies over huurinkomsten, netto rendement, stadskeuze en risicobeheersing voor internationale investeerders."
  path={path}
  schema={[faqSchema(faqs), serviceSchema({ naam: 'Investeren in vastgoed Marokko', beschrijving: 'Investeringsadvies en begeleiding bij vastgoedinvesteringen in Marokko.', path })]}
>
  <Hero
    compact
    eyebrow="Investeringsadvies"
    title="Investeren in Marokkaans vastgoed,<br /><em>met rendement en zekerheid</em>"
    sub="Datagedreven investeringsadvies: de juiste stad, de juiste woning en een onderbouwde inschatting van uw netto rendement, marktdynamiek en risicoprofiel."
    image="/images/villa3.jpg"
    ctas={[
      { label: 'Vraag investeringsanalyse aan', href: '/contact/?doel=investeringsanalyse', primary: true },
      { label: 'Plan adviesgesprek', href: '/adviesgesprek/' },
    ]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Investeren', href: path }]} />
  <AiBlocks path={path} />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <h2>Voor wie is dit?</h2>
      <p>Voor investeerders en eigenaren buiten Marokko die vastgoed inzetten als rendement, spreiding of vermogensopbouw. Sommigen kopen één appartement voor verhuur, anderen bouwen een kleine portefeuille op. In beide gevallen geldt: het rendement ontstaat bij de keuze van stad, object en prijs — niet achteraf.</p>

      <h2>Wat doen wij concreet?</h2>
      <ul class="checks">
        <li><strong>Marktanalyse:</strong> vraag, prijsontwikkeling, verhuurpotentie en aanbod per stad en wijk.</li>
        <li><strong>Rendementsberekening:</strong> bruto én netto, na beheer, onderhoud, belasting, verzekering en leegstand.</li>
        <li><strong>Object- en strategieadvies:</strong> welk type woning past bij uw doel, budget en risicoprofiel.</li>
        <li><strong>Due diligence:</strong> eigendomstitel, kadaster en contract gecontroleerd vóór u zich verbindt.</li>
        <li><strong>Exploitatie na aankoop:</strong> verhuurbeheer en rapportage, zodat het rendement ook daadwerkelijk binnenkomt.</li>
      </ul>

      <h2>Waar zit het rendement?</h2>
      <p>Rendement komt uit twee bronnen, die u samen moet bekijken: <strong>huurinkomsten</strong> — langetermijnverhuur levert doorgaans 5 tot 8% bruto op, toeristische verhuur meer maar wisselender — en <strong>waardegroei</strong>, die het sterkst is in steden met grote infrastructuur- en werkgelegenheidsinvesteringen. Welke van de twee zwaarder weegt, hangt af van uw horizon.</p>

      <h2>Hoe werkt het traject?</h2>
      <ol>
        <li><strong>Intake.</strong> Budget, horizon, gewenst rendement en risicobereidheid.</li>
        <li><strong>Marktselectie.</strong> Twee tot drie steden of wijken die bij uw strategie passen.</li>
        <li><strong>Investeringsanalyse.</strong> Objecten doorgerekend op netto rendement en waardeontwikkeling.</li>
        <li><strong>Due diligence en onderhandeling.</strong> Papieren gecontroleerd, prijs onderbouwd.</li>
        <li><strong>Overdracht en exploitatie.</strong> Officiële overdracht, daarna verhuur en beheer.</li>
      </ol>

      <div class="warn">
        <strong>Rendement op papier is geen rendement in de praktijk.</strong>
        <p>Wees kritisch op te mooie rendementsbeloftes en “gegarandeerde huur”-constructies. Zonder geregistreerde eigendomstitel, een solide ontwikkelaar en goed beheer blijft een mooi percentage een belofte. Wij controleren de onderbouwing.</p>
      </div>

      <h2>Waarom Maghreb Estates?</h2>
      <p>Wij zijn geen verkopende partij. Wij analyseren marktdata uit heel Marokko en vertalen die naar een concreet advies voor úw budget en doel — inclusief het advies om niet te kopen wanneer de cijfers niet kloppen. Onze klanten zijn investeerders uit heel Europa; wij begeleiden hen in het Nederlands, Engels, Frans en Arabisch, en zijn ter plaatse aanwezig voor controle en beheer.</p>

      <p style="margin-top:36px"><a href="/contact/?doel=investeringsanalyse" class="btn btn--primary">Vraag investeringsanalyse aan</a></p>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over investeren in vastgoed in Marokko" />

  <VerderLezen items={[
    { label: 'Steden & markt', href: '/beste-stad-investeren-vastgoed-marokko/', tekst: 'Welke stad past bij welke investeringsstrategie.' },
    { label: 'Nieuwbouw & off-plan', href: '/nieuwbouw-vastgoed-marokko/', tekst: 'Instappen vóór oplevering — kansen en risico’s.' },
    { label: 'Vastgoedbeheer', href: '/vastgoedbeheer-marokko/', tekst: 'Verhuur, onderhoud en rapportage na aankoop.' },
    { label: 'Markten in Marokko', href: '/vastgoed-marokko/', tekst: 'Overzicht van de steden en regio’s waarin wij actief zijn.' },
  ]} />

  <LeadCta path={path} />
</BaseLayout>

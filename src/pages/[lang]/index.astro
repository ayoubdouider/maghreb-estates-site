---
// Vertaalde homepage (Engels, Frans, Arabisch). Volgt dezelfde opbouw als de
// Nederlandse homepage: hero → insights → aanpak → waarom → proces → team →
// korte CTA → footer.
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import ContentBlok from '../../components/ContentBlok.astro';
import { team, teamNetwerk } from '../../data/site';
import { paginas, vertaalTalen, type Taal } from '../../i18n/config';
import { ui } from '../../i18n/ui';
import { content } from '../../i18n/content';

export function getStaticPaths() {
  return vertaalTalen.map((taal) => ({ params: { lang: taal }, props: { taal } }));
}

interface Props { taal: Exclude<Taal, 'nl'> }
const { taal } = Astro.props;

const t = ui[taal];
const pagina = content[taal].home;

// Rollen en bio's van het team zijn in het Nederlands opgeslagen; per taal
// vertaald zodat de teamsectie niet uit de toon valt.
const teamVertaling: Record<Exclude<Taal, 'nl'>, { titel: string; intro: string; netwerk: string; rollen: string[]; bios: string[]; meer: string }> = {
  en: {
    titel: 'Your team for<br /><em>property in Morocco</em>',
    intro: 'You work with recognisable points of contact, supported by a local network of specialists for file review, market information, viewings, management and execution.',
    netwerk: 'Alongside our permanent points of contact, we work with local partners and specialists for viewings, file review, notarial coordination, management and project follow-up.',
    rollen: ['Founder & Real Estate Advisor', 'Real Estate Advisor & Operations'],
    bios: [
      'Ayoub is the founder of Maghreb Estates and advises clients on purchase strategy, property analysis and investment decisions. His focus is on structure, transparency and data-driven decision-making.',
      'Marouane supports market research, client guidance and local follow-up. Together with the wider Maghreb Estates network, he ensures enquiries are handled professionally.',
    ],
    meer: 'More about Maghreb Estates',
  },
  fr: {
    titel: 'Votre équipe pour<br /><em>l’immobilier au Maroc</em>',
    intro: 'Vous travaillez avec des interlocuteurs identifiés, appuyés par un réseau local de spécialistes pour l’examen des dossiers, l’information de marché, les visites, la gestion et l’exécution.',
    netwerk: 'Au-delà de nos interlocuteurs permanents, nous travaillons avec des partenaires et spécialistes locaux pour les visites, l’examen des dossiers, la coordination notariale, la gestion et le suivi de projet.',
    rollen: ['Fondateur & Conseiller immobilier', 'Conseiller immobilier & Opérations'],
    bios: [
      'Ayoub est le fondateur de Maghreb Estates et accompagne les clients sur la stratégie d’achat, l’analyse des biens et les choix d’investissement. Son approche repose sur la structure, la transparence et la décision fondée sur les données.',
      'Marouane intervient sur l’étude de marché, l’accompagnement client et le suivi local. Avec le réseau élargi de Maghreb Estates, il veille au traitement professionnel des demandes.',
    ],
    meer: 'En savoir plus sur Maghreb Estates',
  },
  ar: {
    titel: 'فريقك للعقارات<br /><em>في المغرب</em>',
    intro: 'تتعامل مع جهات اتصال واضحة، مدعومة بشبكة محلية من المختصين في مراجعة الملفات ومعلومات السوق والمعاينات والإدارة والتنفيذ.',
    netwerk: 'إلى جانب جهات الاتصال الدائمة لدينا، نعمل مع شركاء ومختصين محليين في المعاينات ومراجعة الملفات والتنسيق التوثيقي والإدارة ومتابعة المشاريع.',
    rollen: ['المؤسس ومستشار عقاري', 'مستشار عقاري والعمليات'],
    bios: [
      'أيوب هو مؤسس Maghreb Estates ويرافق العملاء في استراتيجية الشراء وتحليل العقارات وقرارات الاستثمار. يركز على البنية والشفافية واتخاذ القرار المبني على البيانات.',
      'مروان يساهم في استكشاف السوق ومرافقة العملاء والمتابعة المحلية. وبالتعاون مع شبكة Maghreb Estates الأوسع، يحرص على معالجة الطلبات بمهنية.',
    ],
    meer: 'المزيد عن Maghreb Estates',
  },
};
const tv = teamVertaling[taal];

const heroCtas = (pagina.heroCtas ?? []).map((soort, i) => ({
  label: soort === 'advies' ? t.cta.advies : t.cta.objectanalyse,
  href: soort === 'advies' ? paginas.adviesgesprek[taal] : `${paginas.contact[taal]}?doel=objectanalyse`,
  primary: i === 0,
}));

// Diensten-kaarten onder het insight-blok.
const diensten = [
  { icon: 'schild', titel: t.footer.aankoop, href: paginas.aankoopbegeleiding[taal] },
  { icon: 'prijs', titel: t.footer.investering, href: paginas.investeren[taal] },
  { icon: 'contract', titel: t.nav.nieuwbouw, href: paginas.nieuwbouw[taal] },
];
---
<BaseLayout
  title={pagina.title}
  description={pagina.description}
  path={paginas.home[taal]}
  taal={taal}
  image={pagina.image}
>
  <Hero
    image={pagina.image}
    eyebrow={pagina.eyebrow}
    title={pagina.h1}
    sub={pagina.sub}
    ctas={heroCtas}
    trust={pagina.trust}
  />

  {/* Insight-blok (datacards) */}
  <section class="section">
    <div class="container">
      <ContentBlok blok={pagina.blokken[0]} />
    </div>
  </section>

  {/* Aanpak + diensten */}
  <section class="section section--tinted">
    <div class="container">
      <div style="max-width:820px">
        <ContentBlok blok={pagina.blokken[1]} />
      </div>
      <div class="grid grid--3" style="margin-top:48px">
        {diensten.map((d) => (
          <a class="card card--link" href={d.href}>
            <span class="card__ic"><Icon name={d.icon} size={26} /></span>
            <h3>{d.titel}</h3>
            <span class="card__more">{t.cta.meer}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Waarom klanten met ons werken */}
  <section class="section">
    <div class="container" style="max-width:820px">
      <ContentBlok blok={pagina.blokken[2]} />
    </div>
  </section>

  {/* Proces */}
  <section class="section section--tinted">
    <div class="container">
      <ContentBlok blok={pagina.blokken[3]} />
    </div>
  </section>

  {/* Team */}
  <section class="section">
    <div class="container">
      <div class="teamsectie">
        <div class="section__header">
          <h2 set:html={tv.titel} />
          <p class="section__desc">{tv.intro}</p>
        </div>
        <div class="teamkaarten">
          {team.map((p, i) => (
            <div class="teamkaart">
              <img class="teamkaart__foto" src={p.foto} alt={p.naam} width="330" height="360" loading="lazy" />
              <div class="teamkaart__body">
                <h3 class="teamkaart__naam">{p.naam}</h3>
                <p class="teamkaart__rol">{tv.rollen[i]}</p>
                <p class="teamkaart__bio">{tv.bios[i]}</p>
                <div class="teamkaart__contact">
                  <a href={`tel:${p.telefoonHref}`} dir="ltr"><Icon name="telefoon" size={16} /> {p.telefoon}</a>
                  <a href={`mailto:${p.email}`} dir="ltr"><Icon name="mail" size={16} /> {p.email}</a>
                </div>
              </div>
            </div>
          ))}
        </div>
        <p style="margin-top:28px;color:var(--text-muted);font-size:15.5px">{tv.netwerk}</p>
        <p style="margin-top:24px"><a href={paginas.overOns[taal]} class="btn btn--outline">{tv.meer}</a></p>
      </div>
    </div>
  </section>

  {/* Korte afsluitende CTA */}
  <section class="ctaband">
    <div class="container">
      <h2>{pagina.slotCta?.titel}</h2>
      <p>{pagina.slotCta?.tekst}</p>
      <a href={paginas.adviesgesprek[taal]} class="btn btn--light">{t.cta.advies}</a>
    </div>
  </section>
</BaseLayout>

---
// Alle vertaalde inhoudspagina's (Engels, Frans, Arabisch).
//
// Eén template voor alle talen en alle inhoudspagina's: de content komt uit
// src/i18n/content/. Zo blijft de opmaak per taal identiek en valt een
// ontbrekende vertaling meteen op bij de build.
//
// Contact en adviesgesprek lopen hier ook doorheen, met een eigen
// formuliercomponent. Dat moet ook: Astro staat maar één dynamische route per
// mapniveau toe, en de adviesgesprek-slug verschilt per taal
// (consultation / rendez-vous-conseil), dus een vast bestand volstaat niet.
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ContentBlok from '../../components/ContentBlok.astro';
import ContactFormulier from '../../components/ContactFormulier.astro';
import BookingFormulier from '../../components/BookingFormulier.astro';
import Faq from '../../components/Faq.astro';
import { paginas, vertaalTalen, type Taal } from '../../i18n/config';
import { ui } from '../../i18n/ui';
import { content } from '../../i18n/content';
import { faqSchema } from '../../data/schema';
import type { Pagina } from '../../i18n/content/types';

export function getStaticPaths() {
  // Alle vertaalde pagina's behalve de homepage, die een eigen bestand heeft.
  const sleutels = [
    'aankoopbegeleiding', 'investeren', 'nieuwbouw', 'kopen', 'kosten', 'overOns',
    'contact', 'adviesgesprek',
  ] as const;

  return vertaalTalen.flatMap((taal) =>
    sleutels.map((sleutel) => {
      const pad = paginas[sleutel][taal];              // bv. /en/purchase-costs/
      const slug = pad.split('/').filter(Boolean)[1];  // -> purchase-costs
      return {
        params: { lang: taal, slug },
        props: { taal, sleutel, pagina: content[taal][sleutel] },
      };
    }),
  );
}

interface Props { taal: Exclude<Taal, 'nl'>; sleutel: keyof typeof paginas; pagina: any }
const { taal, sleutel, pagina } = Astro.props;

const t = ui[taal];
const pad = paginas[sleutel][taal];
const isContact = sleutel === 'contact';
const isBooking = sleutel === 'adviesgesprek';
const isFormulier = isContact || isBooking;
const inhoud = pagina as Pagina;

const heroCtas = (inhoud.heroCtas ?? ['advies']).map((soort, i) => ({
  label: soort === 'advies' ? t.cta.advies : t.cta.objectanalyse,
  href: soort === 'advies' ? paginas.adviesgesprek[taal] : `${paginas.contact[taal]}?doel=objectanalyse`,
  primary: i === 0,
}));
---
<BaseLayout
  title={pagina.title}
  description={pagina.description}
  path={pad}
  taal={taal}
  image={isFormulier ? undefined : inhoud.image}
  schema={!isFormulier && inhoud.faqs?.length ? [faqSchema(inhoud.faqs)] : []}
>
  <Breadcrumbs
    items={[{ label: pagina.eyebrow, href: pad }]}
    home={{ label: t.breadcrumb.home, href: paginas.home[taal] }}
  />

  {isContact && <ContactFormulier taal={taal} pagina={pagina} />}
  {isBooking && <BookingFormulier taal={taal} pagina={pagina} />}

  {!isFormulier && (
    <>
      <Hero
        image={inhoud.image}
        compact={inhoud.compact}
        eyebrow={inhoud.eyebrow}
        title={inhoud.h1}
        sub={inhoud.sub}
        ctas={heroCtas}
        trust={inhoud.trust}
      />

      <section class="section">
        <div class="container" style="max-width:820px">
          {inhoud.blokken.map((blok, i) => (
            <div style={i > 0 ? 'margin-top:56px' : ''}>
              <ContentBlok blok={blok} />
            </div>
          ))}
        </div>
      </section>

      {inhoud.faqs?.length ? <Faq items={inhoud.faqs} title={t.faqTitel} /> : null}

      <section class="ctaband">
        <div class="container">
          <h2>{t.cta.advies}</h2>
          <div class="ctaband__actions">
            <a href={paginas.adviesgesprek[taal]} class="btn btn--light">{t.cta.advies}</a>
            <a href={`${paginas.contact[taal]}?doel=objectanalyse`} class="btn btn--outline">{t.cta.objectanalyse}</a>
          </div>
        </div>
      </section>
    </>
  )}
</BaseLayout>

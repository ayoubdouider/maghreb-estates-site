---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import Definitie from '../components/Definitie.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';
import { faqSchema, articleSchema } from '../data/schema';

const path = '/volmacht-huis-kopen-marokko/';
const faqs = [
  { q: 'Kan ik met een volmacht een huis kopen in Marokko?', a: 'Ja. Met een notariële volmacht (procuration) machtigt u iemand om namens u te handelen — van tekenen van het koopcontract tot de akte bij de notaris. Zo koopt u zonder er zelf telkens bij te hoeven zijn.' },
  { q: 'Hoe regel ik een volmacht vanuit Nederland?', a: 'Een volmacht kan worden opgesteld bij een notaris in Nederland en vervolgens gelegaliseerd/vertaald worden voor gebruik in Marokko, of rechtstreeks bij een Marokkaanse notaris of het consulaat. Wij begeleiden u bij de juiste, veilige vorm.' },
  { q: 'Is een volmacht veilig?', a: 'Een goed opgestelde, specifieke volmacht is veilig: u legt precies vast welke handelingen en grenzen gelden. Een te ruime, algemene volmacht is af te raden. Wij zorgen dat de volmacht beperkt en zorgvuldig is opgesteld.' },
];
---
<BaseLayout
  title="Huis kopen in Marokko met volmacht (procuration) | Maghreb Estates"
  description="Een huis kopen in Marokko met volmacht? Uitleg over de procuration: hoe u er een regelt vanuit Nederland, wat u vastlegt en hoe u het veilig doet. Kopen op afstand mogelijk."
  path={path}
  schema={[faqSchema(faqs), articleSchema({ titel: 'Huis kopen Marokko met volmacht', beschrijving: 'Uitleg over kopen met een volmacht (procuration) in Marokko.', path })]}
>
  <Hero
    compact
    eyebrow="Gids · Volmacht"
    title="Kopen met volmacht<br /><em>(procuration) in Marokko</em>"
    sub="Met een goede volmacht koopt u veilig op afstand. Hoe u er een regelt vanuit Nederland, wat u vastlegt en waar u op let."
    image="/images/villa5.jpg"
    ctas={[{ label: 'Plan gratis adviesgesprek', href: '/contact/', primary: true }]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Gids: volmacht', href: path }]} />
  <AiBlocks path={path} />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <p>Een <strong>huis kopen in Marokko met volmacht</strong> (procuration) maakt het mogelijk om <a href="/huis-kopen-marokko-vanuit-nederland/">op afstand te kopen</a> zonder er telkens bij te zijn. U machtigt een vertrouwenspersoon of onze partij om specifieke handelingen namens u te verrichten.</p>

      <Definitie id="volmacht" />

      <h2>Wat een volmacht kan regelen</h2>
      <ul>
        <li>Het tekenen van het voorlopig koopcontract (compromis de vente).</li>
        <li>Het tekenen van de definitieve akte bij de <a href="/notaris-marokko-vastgoed/">notaris</a>.</li>
        <li>Administratieve stappen rond inschrijving en <a href="/titre-foncier-marokko/">titre foncier</a>.</li>
      </ul>

      <h2>Hoe regelt u het vanuit Nederland?</h2>
      <p>Een volmacht kan worden opgesteld bij een Nederlandse notaris (met legalisatie/vertaling voor Marokko), bij een Marokkaanse notaris of via het consulaat. Wij adviseren welke route in uw geval het meest praktisch en veilig is.</p>

      <h2>Veilig omgaan met een volmacht</h2>
      <p>Belangrijk: houd de volmacht <strong>specifiek en beperkt</strong> — leg precies vast welke handelingen en grenzen gelden. Een te ruime, algemene volmacht is af te raden. Dit hoort bij onze <a href="/aankoopbegeleiding-vastgoed-marokko/">aankoopbegeleiding</a> en de bredere <a href="/risicos-huis-kopen-marokko/">risicobeheersing</a>.</p>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over de volmacht" />
  <CtaBand />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import Faq from '../components/Faq.astro';
import LeadCta from '../components/LeadCta.astro';
import VerderLezen from '../components/VerderLezen.astro';
import { faqSchema, serviceSchema } from '../data/schema';

const path = '/aankoopbegeleiding-vastgoed-marokko/';
const faqs = [
  { q: 'Wat houdt aankoopbegeleiding precies in?', a: 'Wij begeleiden u van A tot Z: wensen bepalen, objecten selecteren en beoordelen, bezichtigen, onderhandelen, volledige dossiercontrole (due diligence) en begeleiding bij notaris, contracten en overdracht. U heeft één vast aanspreekpunt.' },
  { q: 'Zijn jullie onafhankelijk of verkopen jullie eigen objecten?', a: 'Wij zijn onafhankelijk en behartigen uitsluitend uw belang. Wij verdienen niets aan een specifiek object; ons doel is dat u de juiste woning tegen de juiste prijs koopt, met kloppende papieren.' },
  { q: 'Kan de aankoop volledig op afstand worden geregeld?', a: 'Ja. Met een volmacht (procuration) ronden wij het volledige aankooptraject namens u af, inclusief de gang naar de notaris, zodat u niet telkens naar Marokko hoeft te reizen.' },
  { q: 'Wat kost aankoopbegeleiding?', a: 'De kosten hangen af van de dienstverlening en de complexiteit van het dossier. In een adviesgesprek maken wij dit vooraf transparant, zodat u precies weet wat u krijgt en wat het kost.' },
];
---
<BaseLayout
  title="Aankoopbegeleiding vastgoed Marokko | Maghreb Estates"
  description="Onafhankelijke aankoopbegeleiding bij vastgoed in Marokko: selectie, onderhandeling, due diligence, controle van de titre foncier en begeleiding bij notaris en overdracht."
  path={path}
  schema={[faqSchema(faqs), serviceSchema({ naam: 'Aankoopbegeleiding vastgoed Marokko', beschrijving: 'Onafhankelijke aankoopbegeleiding en due diligence bij vastgoed in Marokko.', path })]}
>
  <Hero
    compact
    eyebrow="Aankoopbegeleiding"
    title="Aankoopbegeleiding die<br /><em>onzekerheid wegneemt</em>"
    sub="Onafhankelijke begeleiding en volledige dossiercontrole bij uw aankoop in Marokko. Wij beoordelen het object, controleren de papieren en bewaken dat de overdracht officieel verloopt."
    image="/images/villa2.jpg"
    ctas={[
      { label: 'Laat een object beoordelen', href: '/contact/?doel=aankoopcontrole', primary: true },
      { label: 'Plan adviesgesprek', href: '/contact/' },
    ]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Aankoopbegeleiding', href: path }]} />
  <AiBlocks path={path} />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <h2>Voor wie is dit?</h2>
      <p>Voor internationale kopers en investeerders die zekerheid willen bij een aankoop in Marokko: de koper van een eerste woning of appartement, de investeerder die op rendement stuurt, en de koper van een nieuwbouwproject die de ontwikkelaar wil laten controleren. Vaak koopt u op afstand, terwijl u buiten Marokko woont — juist dan is een onafhankelijke partij ter plaatse doorslaggevend.</p>

      <h2>Wat doen wij concreet?</h2>
      <ul class="checks">
        <li><strong>Wensen &amp; strategie:</strong> eigen gebruik, verhuur of investering — doel, budget en tijdlijn scherp krijgen.</li>
        <li><strong>Selectie &amp; beoordeling:</strong> een eerlijke shortlist met de voor- én nadelen per object, getoetst aan marktdata.</li>
        <li><strong>Onderhandeling:</strong> een realistische prijs, onderbouwd met vergelijkbare transacties.</li>
        <li><strong>Due diligence:</strong> verificatie van de eigendomstitel bij het kadaster, controle op hypotheken en beslagen, en toetsing van het koopcontract.</li>
        <li><strong>Notaris &amp; overdracht:</strong> begeleiding bij de notaris, de contracten en de inschrijving op uw naam.</li>
      </ul>

      <h2>Hoe werkt het traject?</h2>
      <ol>
        <li><strong>Intake.</strong> Uw doel, budget en wensen scherp krijgen.</li>
        <li><strong>Objectselectie of beoordeling.</strong> Een gefilterde shortlist, of analyse van een woning die u zelf gevonden heeft.</li>
        <li><strong>Dossiercheck.</strong> Eigendomstitel, kadaster, contract en — bij nieuwbouw — de ontwikkelaar.</li>
        <li><strong>Marktwaarde en risicoanalyse.</strong> Reële prijs en risico’s helder in beeld.</li>
        <li><strong>Onderhandeling.</strong> Op basis van marktinformatie, in uw belang.</li>
        <li><strong>Notaris en overdracht.</strong> Officieel en controleerbaar, desgewenst met volmacht.</li>
      </ol>

      <div class="warn">
        <strong>Onze belofte: geen aankoop zonder complete dossiercontrole.</strong>
        <p>Ontbreekt een geregistreerde eigendomstitel, klopt het contract niet, of is de ontwikkelaar niet te verifiëren? Dan adviseren wij u niet te kopen — hoe aantrekkelijk het object ook lijkt.</p>
      </div>

      <h2>Waarom Maghreb Estates?</h2>
      <p>Wij zijn onafhankelijk: wij verdienen niets aan een specifiek object en hebben er dus geen belang bij dat u snel koopt. Wat wij toevoegen is lokale aanwezigheid in Marokko, kennis van het kadaster en de notarispraktijk, en een nuchtere beoordeling van prijs en risico. Onze klanten komen uit heel Europa; wij begeleiden hen in het Nederlands, Engels, Frans en Arabisch.</p>
      <p>Het volledige traject kan op afstand: met een <a href="/volmacht-huis-kopen-marokko/">volmacht</a> ronden wij de aankoop tot en met de akte voor u af. Na de overdracht kunnen wij de woning ook <a href="/vastgoedbeheer-marokko/">beheren en verhuren</a>.</p>

      <p style="margin-top:36px"><a href="/contact/?doel=aankoopcontrole" class="btn btn--primary">Laat een object beoordelen</a></p>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over aankoopbegeleiding" />

  <VerderLezen items={[
    { label: 'Kosten bij aankoop', href: '/kosten-huis-kopen-marokko/', tekst: 'Registratierechten, notaris en kadaster — wat u naast de koopsom betaalt.' },
    { label: 'Juridische documenten', href: '/juridische-documenten-vastgoed-marokko/', tekst: 'Welke papieren horen bij een correcte overdracht in Marokko.' },
    { label: 'Vastgoed kopen op afstand', href: '/huis-kopen-marokko-vanuit-nederland/', tekst: 'Hoe een aankoop verloopt terwijl u buiten Marokko bent.' },
    { label: 'Markten in Marokko', href: '/vastgoed-marokko/', tekst: 'Overzicht van de steden en regio’s waarin wij actief zijn.' },
  ]} />

  <LeadCta path={path} />
</BaseLayout>

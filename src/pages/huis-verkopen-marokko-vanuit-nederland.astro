---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';
import { faqSchema, serviceSchema } from '../data/schema';

const path = '/huis-verkopen-marokko-vanuit-nederland/';
const faqs = [
  { q: 'Kan ik mijn huis in Marokko verkopen vanuit Nederland?', a: 'Ja. Wij begeleiden de verkoop op afstand: waardebepaling, presentatie, bezichtigingen, onderhandeling en de gang naar de notaris. Met een volmacht kunnen wij de overdracht namens u afronden.' },
  { q: 'Hoe bepaal ik de juiste vraagprijs in Marokko?', a: 'Wij maken een realistische waardebepaling op basis van markdata en vergelijkbare objecten in uw stad. Een correcte prijs voorkomt langdurige leegstand of onderverkoop.' },
  { q: 'Wat komt er kijken bij de overdracht bij verkoop?', a: 'De verkoop verloopt officieel via de notaris, met controle van de eigendomstitel en afhandeling van eventuele belastingen. Wij begeleiden het hele traject tot de overdracht.' },
];
---
<BaseLayout
  title="Huis verkopen in Marokko vanuit Nederland | Maghreb Estates"
  description="Uw huis verkopen in Marokko vanuit Nederland? Verkoopbegeleiding met realistische waardebepaling, presentatie, onderhandeling en notaris. Nederlandstalig en transparant."
  path={path}
  schema={[faqSchema(faqs), serviceSchema({ naam: 'Huis verkopen Marokko', beschrijving: 'Verkoopbegeleiding van vastgoed in Marokko voor eigenaren in Nederland.', path })]}
>
  <Hero
    compact
    eyebrow="Verkoopbegeleiding"
    title="Uw huis verkopen in Marokko,<br /><em>begeleid tot de overdracht</em>"
    sub="Van realistische waardebepaling tot de akte bij de notaris — wij verkopen uw Marokkaanse woning correct, ook vanuit Nederland."
    image="/images/villa5.jpg"
    ctas={[{ label: 'Plan gratis adviesgesprek', href: '/contact/', primary: true }]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Huis verkopen', href: path }]} />
  <AiBlocks path={path} />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <p>Uw <strong>huis verkopen in Marokko vanuit Nederland</strong> vraagt om lokale kennis en een correcte afhandeling. Wij begeleiden de verkoop van A tot Z, zodat u een goede prijs krijgt en de overdracht juridisch klopt — zonder dat u er telkens voor hoeft af te reizen.</p>

      <h2>Onze verkoopbegeleiding</h2>
      <ul>
        <li><strong>Waardebepaling:</strong> een realistische vraagprijs op basis van markdata.</li>
        <li><strong>Presentatie:</strong> goede foto’s en een aantrekkelijke advertentie.</li>
        <li><strong>Bezichtigingen & onderhandeling:</strong> wij vertegenwoordigen u ter plaatse.</li>
        <li><strong>Notaris & overdracht:</strong> begeleiding bij de <a href="/notaris-marokko-vastgoed/">notaris</a>, met controle van de <a href="/titre-foncier-marokko/">eigendomstitel</a>.</li>
      </ul>

      <h2>Verkopen op afstand</h2>
      <p>Net als bij <a href="/huis-kopen-marokko-vanuit-nederland/">kopen op afstand</a> kunnen wij met een <a href="/volmacht-huis-kopen-marokko/">volmacht</a> de overdracht namens u afronden.</p>

      <h2>Verkopen of juist verhuren?</h2>
      <p>Twijfelt u tussen verkopen en aanhouden? Bereken eerst het <a href="/rendement-vastgoed-marokko/">rendement bij verhuur</a> — soms is <a href="/vastgoedbeheer-marokko/">verhuren en beheren</a> aantrekkelijker dan verkopen.</p>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over huis verkopen in Marokko" />
  <CtaBand title="Uw woning verkopen?" text="Plan een gesprek over de verkoop. Wij maken een realistische waardebepaling en vertellen u wat haalbaar is." />
</BaseLayout>

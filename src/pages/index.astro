---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import CardSlider from '../components/CardSlider.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';
import { steden } from '../data/steden';
import { team, homeMarkten } from '../data/site';
import { faqSchema } from '../data/schema';

// Bewust kort gehouden op de homepage: vier vragen die een oriënterende bezoeker
// stelt. Verdieping staat in de kennisbank, niet hier.
const faqs = [
  { q: 'Voor wie werkt Maghreb Estates?', a: 'Voor internationale kopers, investeerders en eigenaren die vastgoed in Marokko willen kopen, laten renderen of verkopen — meestal vanuit het buitenland. Wij begeleiden klanten uit Europa in het Nederlands, Engels, Frans en Arabisch.' },
  { q: 'Wat doen jullie precies?', a: 'Aankoopadvies en due diligence, investeringsanalyse, en beheer en verkoop na aankoop. Wij zijn onafhankelijk: wij verdienen niets aan een specifiek object en behartigen uitsluitend uw belang.' },
  { q: 'Kan een aankoop volledig op afstand worden geregeld?', a: 'Ja. Met een volmacht ronden wij het volledige traject af, inclusief de akte bij de notaris, zodat u niet telkens naar Marokko hoeft te reizen.' },
  { q: 'Wat kost een adviesgesprek?', a: 'Het eerste gesprek is vrijblijvend. We luisteren naar uw situatie en vertellen u eerlijk wat mogelijk is en wat het traject kost.' },
];

const markten = homeMarkten
  .map((m) => steden.find((s) => s.slug === m.slug))
  .filter((s): s is NonNullable<typeof s> => Boolean(s));
---
<BaseLayout
  title="Vastgoed kopen, investeren en beheren in Marokko | Maghreb Estates"
  description="Maghreb Estates begeleidt internationale kopers en investeerders bij vastgoed in Marokko. Van aankoopadvies en due diligence tot verhuur, beheer en verkoop."
  path="/"
  schema={[faqSchema(faqs)]}
>
  <Hero
    eyebrow="International real estate advisory · Marokko"
    title="Vastgoed kopen, investeren en<br /><em>beheren in Marokko</em>"
    sub="Maghreb Estates begeleidt internationale kopers en investeerders bij vastgoed in Marokko. Van aankoopadvies en due diligence tot verhuur, beheer en verkoop — met lokale marktkennis en transparante begeleiding."
    image="/images/villa5.jpg"
    ctas={[
      { label: 'Plan adviesgesprek', href: '/contact/', primary: true },
      { label: 'Laat een object beoordelen', href: '/contact/?doel=aankoopcontrole' },
    ]}
    trust={['Aankoopadvies', 'Due diligence', 'Investeringsanalyse', 'Vastgoedbeheer']}
  />

  <!-- DRIE HOOFDSERVICES -->
  <section class="section section--tinted">
    <div class="container">
      <div class="section__header section__header--center">
        <p class="eyebrow">Onze diensten</p>
        <h2>Drie manieren waarop wij u begeleiden</h2>
      </div>
      <div class="grid grid--3">
        <a class="card card--link" href="/aankoopbegeleiding-vastgoed-marokko/">
          <span class="card__ic"><Icon name="schild" size={26} /></span>
          <h3>Aankoopadvies</h3>
          <p>Objectselectie, onderhandeling en volledige dossiercontrole — van eigendomstitel tot overdracht bij de notaris.</p>
          <span class="card__more">Meer over aankoopadvies</span>
        </a>
        <a class="card card--link" href="/investeren-vastgoed-marokko/">
          <span class="card__ic"><Icon name="prijs" size={26} /></span>
          <h3>Investeringsadvies</h3>
          <p>Nuchtere analyse van netto rendement, stad- en objectkeuze en risico — onderbouwd met marktdata.</p>
          <span class="card__more">Meer over investeren</span>
        </a>
        <a class="card card--link" href="/vastgoedbeheer-marokko/">
          <span class="card__ic"><Icon name="beheer" size={26} /></span>
          <h3>Beheer & verkoop</h3>
          <p>Verhuur, onderhoud en toezicht op afstand, en begeleiding wanneer u uw woning weer wilt verkopen.</p>
          <span class="card__more">Meer over beheer & verkoop</span>
        </a>
      </div>
    </div>
  </section>

  <!-- WERKWIJZE -->
  <section class="section">
    <div class="container">
      <div class="section__header section__header--center">
        <p class="eyebrow">Werkwijze</p>
        <h2>Vier stappen, helder afgebakend</h2>
      </div>
      <CardSlider cols={4} hint="Veeg door de stappen">
        <div class="card"><span class="card__num">1</span><h3>Intake</h3><p>Uw doel, budget en tijdlijn scherp krijgen — eigen gebruik, rendement of beide.</p></div>
        <div class="card"><span class="card__num">2</span><h3>Object- en dossieranalyse</h3><p>Eigendomstitel, contract, prijs en locatie objectief beoordeeld.</p></div>
        <div class="card"><span class="card__num">3</span><h3>Advies & onderhandeling</h3><p>Een onderbouwd advies en onderhandeling op basis van marktinformatie.</p></div>
        <div class="card"><span class="card__num">4</span><h3>Overdracht of beheer</h3><p>Officiële overdracht bij de notaris, daarna optioneel verhuur en beheer.</p></div>
      </CardSlider>
    </div>
  </section>

  <!-- MARKTEN -->
  <section class="section section--tinted" id="markten">
    <div class="container">
      <div class="markten">
        <div class="markten__intro">
          <p class="eyebrow">Selectie van markten</p>
          <h2>Waar wij actief zijn</h2>
          <p class="section__desc">Elke stad kent een eigen markt en een eigen risicoprofiel. Wij beoordelen elk object binnen die context.</p>
        </div>
        <div class="markten__links">
          {markten.map((s) => (
            <a class="markt-link" href={`/vastgoed-${s.slug}/`}>
              <strong>{s.naam}</strong>
              <span>{s.regio}</span>
            </a>
          ))}
          <a class="markt-link markt-link--alle" href="/vastgoed-marokko/">
            <strong>Alle markten</strong>
            <span>Volledig overzicht</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TEAM & VERTROUWEN -->
  <section class="section">
    <div class="container">
      <div class="teamsectie">
        <div class="section__header">
          <p class="eyebrow">Ons team</p>
          <h2>Persoonlijk contact met<br /><em>mensen die de markt kennen</em></h2>
          <p class="section__desc">Twee adviseurs, één vast aanspreekpunt. Wij begeleiden klanten uit Europa in het Nederlands, Engels, Frans en Arabisch.</p>
        </div>
        <div class="teamkaarten">
          {team.map((p) => (
            <div class="teamkaart">
              <img class="teamkaart__foto" src={p.foto} alt={p.naam} width="330" height="360" loading="lazy" />
              <div class="teamkaart__body">
                <h3 class="teamkaart__naam">{p.naam}</h3>
                <p class="teamkaart__rol">{p.rol}</p>
                <div class="teamkaart__contact">
                  <a href={`tel:${p.telefoonHref}`}><Icon name="telefoon" size={16} /> {p.telefoon}</a>
                  <a href={`mailto:${p.email}`}><Icon name="mail" size={16} /> {p.email}</a>
                </div>
              </div>
            </div>
          ))}
        </div>
        <p style="margin-top:28px"><a href="/over-ons/" class="btn btn--outline">Meer over Maghreb Estates</a></p>
      </div>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen" />

  <CtaBand
    title="Plan een adviesgesprek"
    text="Een vrijblijvend gesprek over uw situatie — kopen, investeren, beheren of verkopen. Wij vertellen u eerlijk wat mogelijk is."
    label="Plan adviesgesprek"
  />
</BaseLayout>

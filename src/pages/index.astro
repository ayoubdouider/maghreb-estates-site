---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import { team, teamNetwerk } from '../data/site';

// Bewust rustige homepage: hero → data/insights → aanpak → waarom → proces →
// team → korte CTA → footer. Geen stedenblok, geen FAQ, geen kennisbankdump.
// Die pagina's blijven volledig indexeerbaar via footer, /vastgoed-marokko/,
// /kennisbank/ en de sitemap, maar staan niet in de zichtbare klantreis.

const datacards = [
  {
    icon: 'grafiek',
    titel: 'Marktvergelijking',
    tekst: 'Wij vergelijken vraagprijzen met beschikbare marktinformatie, referentieobjecten en lokale prijsniveaus.',
  },
  {
    icon: 'prijs',
    titel: 'Rendementsindicatie',
    tekst: 'Voor investeerders maken wij onderscheid tussen bruto huurpotentie, netto resultaat, beheerlasten en leegstandsrisico.',
  },
  {
    icon: 'weegschaal',
    titel: 'Objectscore',
    tekst: 'Wij beoordelen locatie, staat, juridische documenten, verhuurbaarheid en exit-potentie in één overzicht.',
  },
  {
    icon: 'dashboard',
    titel: 'Dashboard & rapportage',
    tekst: 'Waar mogelijk werken wij met dashboards en objectrapportages om keuzes inzichtelijk en bespreekbaar te maken.',
  },
];

const stappen = [
  { titel: 'Intake & doelstelling', tekst: 'We bepalen uw doel, budget, voorkeursregio en gewenste rol van Maghreb Estates.' },
  { titel: 'Markt- en objectanalyse', tekst: 'We beoordelen locatie, prijsniveau, verhuurpotentie, ontwikkelaar of verkoper en beschikbare marktdata.' },
  { titel: 'Dossier & due diligence', tekst: 'We controleren relevante documenten, eigendomsinformatie, contractvoorwaarden en aandachtspunten voor overdracht.' },
  { titel: 'Advies & uitvoering', tekst: 'U ontvangt een helder advies. Daarna begeleiden wij bij onderhandeling, overdracht, beheer of vervolgstappen.' },
];

const redenen = [
  'Datagedreven objectanalyse',
  'Lokale aanwezigheid in Marokko',
  'Due diligence vóór aankoop',
  'Meertalige begeleiding',
  'Ondersteuning bij aankoop, investering en beheer',
];
---
<BaseLayout
  title="Vastgoed kopen en investeren in Marokko | Maghreb Estates"
  description="Maghreb Estates begeleidt internationale kopers en investeerders bij vastgoed in Marokko: aankoopadvies, investeringsanalyse, due diligence en marktdata."
  path="/"
>
  <Hero
    image="/images/villa4.jpg"
    eyebrow="International real estate advisory · Morocco"
    title="Vastgoed kopen en<br /><em>investeren in Marokko</em>"
    sub="Maghreb Estates begeleidt internationale kopers en investeerders bij vastgoed in Marokko. Met lokale marktkennis, data-analyse en professionele due diligence helpen wij u betere aankoop- en investeringsbeslissingen nemen."
    ctas={[
      { label: 'Plan adviesgesprek', href: '/adviesgesprek/', primary: true },
      { label: 'Laat een object analyseren', href: '/contact/?doel=objectanalyse' },
    ]}
    trust={['Aankoopadvies', 'Investeringsanalyse', 'Due diligence', 'Marktdata', 'Begeleiding in Marokko']}
  />

  <!-- DATA & INSIGHTS — de kern-USP, direct na de hero -->
  <section class="section">
    <div class="container">
      <div class="section__header" style="max-width:820px">
        <p class="eyebrow">Insights</p>
        <h2>Beslissen op basis van inzicht,<br /><em>niet alleen gevoel</em></h2>
        <p class="section__desc">De Marokkaanse vastgoedmarkt is lokaal, versnipperd en vaak weinig transparant. Maghreb Estates brengt structuur aan in die markt. Wij analyseren objecten op prijs, locatie, verhuurpotentie, marktdynamiek en dossierkwaliteit, zodat u niet alleen ziet wat een woning kost, maar ook hoe sterk de onderliggende investering is.</p>
      </div>
      <div class="datacards">
        {datacards.map((c) => (
          <div class="datacard">
            <span class="datacard__ic"><Icon name={c.icon} size={24} /></span>
            <h3>{c.titel}</h3>
            <p>{c.tekst}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DIENSTEN -->
  <section class="section section--tinted">
    <div class="container">
      <div class="section__header" style="max-width:820px">
        <p class="eyebrow">Onze aanpak</p>
        <h2>Marktdata, juridische controle<br /><em>en lokale kennis samen</em></h2>
        <p class="section__desc">Een vastgoedbeslissing wordt sterker wanneer marktdata, juridische controle en lokale kennis samenkomen. Daarom combineren wij objectanalyse, prijsvergelijking, documentcontrole en begeleiding ter plaatse in één helder proces.</p>
      </div>
      <div class="grid grid--3">
        <a class="card card--link" href="/aankoopbegeleiding-vastgoed-marokko/">
          <span class="card__ic"><Icon name="schild" size={26} /></span>
          <h3>Aankoopbegeleiding</h3>
          <p>Objectselectie, marktvergelijking, onderhandeling en due diligence tot en met de overdracht bij de notaris.</p>
          <span class="card__more">Meer over aankoopbegeleiding</span>
        </a>
        <a class="card card--link" href="/investeren-vastgoed-marokko/">
          <span class="card__ic"><Icon name="prijs" size={26} /></span>
          <h3>Investeringsadvies</h3>
          <p>Analyse van netto rendement, stad- en objectkeuze en risicoprofiel, onderbouwd met marktdata.</p>
          <span class="card__more">Meer over investeren</span>
        </a>
        <a class="card card--link" href="/nieuwbouw-vastgoed-marokko/">
          <span class="card__ic"><Icon name="contract" size={26} /></span>
          <h3>Nieuwbouw &amp; off-plan</h3>
          <p>Beoordeling van ontwikkelaar, vergunningen, contractvoorwaarden, betalingsstructuur en oplevering.</p>
          <span class="card__more">Meer over nieuwbouw</span>
        </a>
      </div>
    </div>
  </section>

  <!-- WAAROM KLANTEN MET ONS WERKEN -->
  <section class="section">
    <div class="container">
      <div class="split">
        <div class="split__text">
          <p class="eyebrow">Waarom Maghreb Estates</p>
          <h2>Waarom klanten met<br /><em>Maghreb Estates werken</em></h2>
          <p class="section__desc">Klanten schakelen ons in wanneer zij professionele begeleiding willen in een markt die lokaal sterk verschilt per stad, wijk en ontwikkelaar. Wij brengen structuur in het aankoopproces, combineren lokale aanwezigheid met data-analyse en begeleiden elke stap richting een goed onderbouwde beslissing.</p>
        </div>
        <div>
          <ul class="checks">
            {redenen.map((r) => <li>{r}</li>)}
          </ul>
          <p style="color:var(--text-muted);font-size:15.5px;margin-top:20px">Wij werken voor kopers, investeerders en eigenaren die in Marokko vastgoed willen aankopen, beoordelen, verhuren, beheren of verkopen — met een professioneel proces en heldere communicatie.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOE WIJ WERKEN (werkwijze + controle + stappen samengevoegd) -->
  <section class="section section--tinted">
    <div class="container">
      <div class="section__header" style="max-width:820px">
        <p class="eyebrow">Proces</p>
        <h2>Hoe wij werken</h2>
        <p class="section__desc">Elke opdracht begint met een helder doel: aankopen, investeren, verkopen of beheren. Daarna brengen wij de markt, het object en het dossier stap voor stap in kaart.</p>
      </div>
      <ol class="stappen">
        {stappen.map((s, i) => (
          <li class="stap">
            <span class="stap__num">Stap {i + 1}</span>
            <h3>{s.titel}</h3>
            <p>{s.tekst}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- TEAM -->
  <section class="section">
    <div class="container">
      <div class="teamsectie">
        <div class="section__header">
          <p class="eyebrow">Ons team</p>
          <h2>Uw team voor<br /><em>vastgoed in Marokko</em></h2>
          <p class="section__desc">U werkt met herkenbare aanspreekpunten, ondersteund door een lokaal netwerk van specialisten voor dossiercontrole, marktinformatie, bezichtigingen, beheer en uitvoering.</p>
        </div>
        <div class="teamkaarten">
          {team.map((p) => (
            <div class="teamkaart">
              {/* TODO: vervang de foto van Marouane door een portret met dezelfde
                  achtergrond en belichting als die van Ayoub (zie site.ts). */}
              <img class="teamkaart__foto" src={p.foto} alt={p.naam} width="330" height="360" loading="lazy" />
              <div class="teamkaart__body">
                <h3 class="teamkaart__naam">{p.naam}</h3>
                <p class="teamkaart__rol">{p.rol}</p>
                <p class="teamkaart__bio">{p.bio}</p>
                <div class="teamkaart__contact">
                  <a href={`tel:${p.telefoonHref}`}><Icon name="telefoon" size={16} /> {p.telefoon}</a>
                  <a href={`mailto:${p.email}`}><Icon name="mail" size={16} /> {p.email}</a>
                </div>
              </div>
            </div>
          ))}
        </div>
        <p style="margin-top:28px;color:var(--text-muted);font-size:15.5px">{teamNetwerk}</p>
        <p style="margin-top:24px"><a href="/over-ons/" class="btn btn--outline">Meer over Maghreb Estates</a></p>
      </div>
    </div>
  </section>

  <!-- KORTE AFSLUITENDE CTA — daarna alleen de footer -->
  <section class="ctaband">
    <div class="container">
      <h2>Wilt u een object laten analyseren of uw mogelijkheden bespreken?</h2>
      <p>Plan een adviesgesprek met Maghreb Estates.</p>
      <a href="/adviesgesprek/" class="btn btn--light">Plan adviesgesprek</a>
    </div>
  </section>
</BaseLayout>

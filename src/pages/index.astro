---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import CtaInline from '../components/CtaInline.astro';
import Icon from '../components/Icon.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';
import { steden } from '../data/steden';
import { team, waLink, prominenteSteden } from '../data/site';
import { faqSchema } from '../data/schema';

const faqs = [
  { q: 'Kan ik als Nederlander veilig vastgoed kopen in Marokko?', a: 'Ja. Nederlanders, Belgen en Nederlands-Marokkanen mogen vrijwel overal in Marokko vastgoed kopen, ook op afstand. Veilig kopen staat of valt met controle van de eigendomstitel en een officiële overdracht via de notaris. Zonder complete dossiercontrole adviseren wij niet te tekenen.' },
  { q: 'Wat kost het kopen van een huis in Marokko?', a: 'Naast de koopsom betaalt u circa 6 tot 10% aan bijkomende kosten: registratierechten, notaris en kadaster. Wij maken vooraf een transparante berekening voor uw situatie, zodat u niet voor verborgen kosten komt te staan.' },
  { q: 'Hoe voorkom ik oplichting bij vastgoed in Marokko?', a: 'De grootste risico’s zijn onduidelijke eigendomspapieren, dubbele verkoop en betalingen buiten de notaris om. Wij verifiëren de titre foncier bij het kadaster, controleren of de verkoper bevoegd is en laten alles officieel verlopen.' },
  { q: 'Ben ik niet afhankelijk van familie of tussenpersonen?', a: 'Nee. Veel kopers regelen het via een oom, neef of kennis en lopen vast in onduidelijke afspraken. Wij zijn een onafhankelijke partij die uitsluitend uw belang behartigt.' },
  { q: 'Kan Maghreb Estates ook mijn woning verhuren en beheren?', a: 'Ja. Wij verzorgen verhuur- en vastgoedbeheer op afstand: van huurders vinden en Airbnb-beheer tot onderhoud en toezicht.' },
  { q: 'Wat kost een adviesgesprek?', a: 'Het eerste gesprek is gratis en vrijblijvend. We luisteren naar uw situatie en vertellen u eerlijk wat mogelijk is.' },
];

const topSteden = steden.filter((s) => prominenteSteden.some((p) => p.slug === s.slug));
---
<BaseLayout
  title="Vastgoed kopen in Marokko, zonder blind vertrouwen | Maghreb Estates"
  description="Maghreb Estates begeleidt Nederlanders, Belgen en Nederlands-Marokkanen bij het kopen, beoordelen en beheren van vastgoed in Marokko. Wij controleren eerst het dossier, de prijs en de risico’s."
  path="/"
  schema={[faqSchema(faqs)]}
>
  <Hero
    eyebrow="Aankoopbegeleiding & vastgoedbeheer in Marokko"
    title="Vastgoed kopen in Marokko,<br /><em>zonder blind vertrouwen</em>"
    sub="Maghreb Estates begeleidt Nederlanders, Belgen en Nederlands-Marokkanen bij het kopen, beoordelen en beheren van vastgoed in Marokko. Wij controleren eerst het dossier, de prijs en de risico’s — pas daarna kijken we of een aankoop verstandig is."
    image="/images/villa5.jpg"
    ctas={[
      { label: 'Stuur een woning ter controle', href: '/contact/?doel=aankoopcontrole', primary: true },
      { label: 'Plan gratis adviesgesprek', href: '/contact/' },
    ]}
    trust={['Nederlandstalige begeleiding', 'Lokale controle', 'Dossiercheck vóór betaling', 'Beheer na aankoop']}
  />


  <!-- WAAR WIJ OP CONTROLEREN -->
  <section class="section section--tinted">
    <div class="container">
      <div class="section__header section__header--center">
        <p class="eyebrow">Onze werkwijze</p>
        <h2>Waar wij op controleren voordat u koopt</h2>
        <p class="section__desc">Een woning in Marokko kopen gaat mis vóór de notaris, niet erna. Daarom begint elke aankoop bij ons met controle — niet bij de prijs.</p>
      </div>
      <div class="grid grid--4">
        <div class="card">
          <span class="card__ic"><Icon name="titel" size={28} /></span>
          <h3>Eigendomstitel</h3>
          <p>We controleren of de woning correct geregistreerd is en of de verkoper bevoegd is om te verkopen.</p>
        </div>
        <div class="card">
          <span class="card__ic"><Icon name="contract" size={28} /></span>
          <h3>Koopcontract</h3>
          <p>We beoordelen voorwaarden, aanbetaling, leverdatum en risico’s vóórdat u tekent.</p>
        </div>
        <div class="card">
          <span class="card__ic"><Icon name="prijs" size={28} /></span>
          <h3>Prijs en locatie</h3>
          <p>We vergelijken de vraagprijs met marktinformatie en beoordelen of het object bij uw doel past.</p>
        </div>
        <div class="card">
          <span class="card__ic"><Icon name="notaris" size={28} /></span>
          <h3>Notaris en overdracht</h3>
          <p>We bewaken dat betalingen en overdracht officieel en controleerbaar verlopen.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WAAROM KOPERS ONS INSCHAKELEN -->
  <section class="section">
    <div class="container">
      <div class="split">
        <div class="split__text">
          <p class="eyebrow">Waarom kopers ons inschakelen</p>
          <h2 style="margin-bottom:22px">Onafhankelijk, en eerlijk wanneer iets niet klopt</h2>
          <p style="color:var(--text-muted);font-size:17px;margin-bottom:18px">Een woning kopen in Marokko is vaak emotioneel én financieel groot. Juist daarom wilt u niet afhankelijk zijn van losse tips, familieconstructies of mooie verkoopverhalen.</p>
          <p style="color:var(--text-muted);font-size:17px;margin-bottom:28px">Maghreb Estates werkt als onafhankelijke begeleider: wij zoeken mee, controleren documenten, beoordelen risico’s en zeggen het ook eerlijk wanneer een object niet klopt.</p>
          <a href="/contact/?doel=aankoopcontrole" class="btn btn--primary">Laat uw aankoop controleren</a>
        </div>
        <div class="split__visual">
          <div class="quote-block">
            <blockquote>“Wij helpen u niet alleen zoeken, maar vooral voorkomen dat u verkeerd koopt.”</blockquote>
            <cite>— Maghreb Estates</cite>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIENSTEN -->
  <section class="section section--tinted">
    <div class="container">
      <div class="section__header section__header--center">
        <p class="eyebrow">Waarmee wij helpen</p>
        <h2>Van aankoop tot beheer, op één plek</h2>
        <p class="section__desc">U heeft één vast, Nederlandstalig aanspreekpunt — van de eerste oriëntatie tot verhuur en beheer na aankoop.</p>
      </div>
      <div class="grid grid--3">
        <a class="card card--link" href="/huis-kopen-marokko/">
          <span class="card__ic"><Icon name="sleutel" size={26} /></span>
          <h3>Huis kopen</h3>
          <p>Van woning tot appartement of villa: wij selecteren, beoordelen en begeleiden uw aankoop tot de overdracht.</p>
          <span class="card__more">Meer over kopen</span>
        </a>
        <a class="card card--link" href="/investeren-vastgoed-marokko/">
          <span class="card__ic"><Icon name="prijs" size={26} /></span>
          <h3>Investeren</h3>
          <p>Nuchter advies over realistisch rendement na kosten, huurinkomsten en de keuze van stad en object.</p>
          <span class="card__more">Meer over investeren</span>
        </a>
        <a class="card card--link" href="/aankoopbegeleiding-vastgoed-marokko/">
          <span class="card__ic"><Icon name="schild" size={26} /></span>
          <h3>Aankoopbegeleiding</h3>
          <p>Dossiercontrole, verificatie van de titre foncier, notaris en contracten. Wij verkleinen de onzekerheid.</p>
          <span class="card__more">Meer over begeleiding</span>
        </a>
        <a class="card card--link" href="/vastgoedbeheer-marokko/">
          <span class="card__ic"><Icon name="beheer" size={26} /></span>
          <h3>Vastgoedbeheer</h3>
          <p>Verhuurbeheer, Airbnb-beheer, onderhoud en toezicht terwijl u in Nederland bent.</p>
          <span class="card__more">Meer over beheer</span>
        </a>
        <a class="card card--link" href="/huis-kopen-marokko-vanuit-nederland/">
          <span class="card__ic"><Icon name="afstand" size={26} /></span>
          <h3>Kopen op afstand</h3>
          <p>Het volledige aankooptraject vanuit Nederland, desgewenst met een beperkte volmacht.</p>
          <span class="card__more">Kopen vanuit Nederland</span>
        </a>
        <a class="card card--link" href="/huis-verkopen-marokko-vanuit-nederland/">
          <span class="card__ic"><Icon name="contract" size={26} /></span>
          <h3>Verkoopbegeleiding</h3>
          <p>Uw Marokkaanse woning verkopen vanuit Nederland, met een reële waardebepaling en officiële overdracht.</p>
          <span class="card__more">Meer over verkopen</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ONS TEAM -->
  <section class="section">
    <div class="container">
      <div class="teamsectie">
        <div class="section__header">
          <p class="eyebrow">Ons team</p>
          <h2>Persoonlijk contact met<br /><em>mensen die het kennen</em></h2>
          <p class="section__desc">Wij zijn twee adviseurs met kennis van zowel de Nederlandse als de Marokkaanse markt. U heeft altijd een vast aanspreekpunt.</p>
        </div>
        <div class="teamkaarten">
          {team.map((p) => (
            <div class="teamkaart">
              <img class="teamkaart__foto" src={p.foto} alt={p.naam} width="330" height="360" loading="lazy" />
              <div class="teamkaart__body">
                <h3 class="teamkaart__naam">{p.naam}</h3>
                <p class="teamkaart__rol">Real estate agent</p>
                <div class="teamkaart__contact">
                  <a href={`tel:${p.telefoonHref}`}><Icon name="telefoon" size={16} /> {p.telefoon}</a>
                  <a href={`mailto:${p.email}`}><Icon name="mail" size={16} /> {p.email}</a>
                </div>
              </div>
            </div>
          ))}
        </div>
        <p style="margin-top:28px"><a href="/over-ons/" class="btn btn--outline">Meer over Maghreb Estates</a></p>
      </div>
    </div>
  </section>

  <!-- STEDEN -->
  <section class="section section--tinted" id="steden">
    <div class="container">
      <div class="section__header section__header--center">
        <p class="eyebrow">Waar wij actief zijn</p>
        <h2>Vastgoed per stad in Marokko</h2>
        <p class="section__desc">Van Tanger en Nador in het noorden tot Marrakech en Agadir. Elke stad heeft een eigen markt; wij beoordelen elk object afzonderlijk.</p>
      </div>
      <div class="steden">
        {topSteden.map((s) => (
          <a class="stad-chip" href={`/vastgoed-${s.slug}/`}>
            <strong>{s.naam}</strong>
            <span>{s.regio}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCES -->
  <section class="section">
    <div class="container">
      <div class="section__header section__header--center">
        <p class="eyebrow">Hoe het werkt</p>
        <h2>Van eerste vraag tot overdracht</h2>
      </div>
      <div class="grid grid--4">
        <div class="card"><span class="card__num">1</span><h3>Kennismaking</h3><p>Een vrijblijvend gesprek over uw situatie, doel en budget.</p></div>
        <div class="card"><span class="card__num">2</span><h3>Selectie & controle</h3><p>Een gefilterde selectie, of controle van uw eigen object, met eerlijke analyse.</p></div>
        <div class="card"><span class="card__num">3</span><h3>Dossier & bezichtiging</h3><p>Papiercontrole en bezichtiging, ter plaatse of op afstand via video.</p></div>
        <div class="card"><span class="card__num">4</span><h3>Notaris & beheer</h3><p>Officiële overdracht bij de notaris, daarna optioneel verhuur en beheer.</p></div>
      </div>
      <div class="container" style="padding:0;max-width:820px;margin-top:44px">
        <CtaInline
          title="Niet zeker waar u moet beginnen?"
          text="Plan een gratis, vrijblijvend adviesgesprek. Wij luisteren en maken een helder plan — kopen, investeren of beheren."
        />
      </div>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over vastgoed in Marokko" />

  <CtaBand />
</BaseLayout>

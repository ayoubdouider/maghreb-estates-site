---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import MarketDisclaimer from '../components/MarketDisclaimer.astro';
import Faq from '../components/Faq.astro';
import LeadCta from '../components/LeadCta.astro';
import { faqSchema, articleSchema } from '../data/schema';

const path = '/kosten-huis-kopen-marokko/';
// Bewust geen totaalpercentage en geen makelaars-/courtagekosten: die zijn geen
// klantkosten in onze dienstverlening en maken het beeld misleidend. Fiscale
// details over verhuur staan hier niet meer — te onderhoudsgevoelig en beter
// besproken per dossier.
const faqs = [
  { q: 'Welke kosten komen er naast de koopsom bij?', a: 'U krijgt te maken met officiële aankoopkosten: registratierechten, notariskosten, kadaster- of inschrijvingskosten, zegelrechten en eventuele bank- of administratieve kosten. De exacte kosten verschillen per dossier, aankoopvorm en object.' },
  { q: 'Wat zijn de notariskosten in Marokko?', a: 'De notariskosten (honoraires) liggen doorgaans rond 0,5 tot 1% van de koopsom, plus zegel- en administratiekosten. De notaris int daarnaast de registratierechten en schrijft de akte in bij het kadaster.' },
  { q: 'Welke terugkerende kosten heb ik na de aankoop?', a: 'Reken op lokale belastingen (onder meer de taxe de services communaux), servicekosten (syndic) bij appartementen, onderhoud, verzekering en eventuele bankkosten. Bij verhuur of beheer komen daar afspraken bij die per situatie verschillen.' },
  { q: 'Wat kost begeleiding door Maghreb Estates?', a: 'Onze rol en vergoeding worden vooraf duidelijk besproken. Bij sommige projecten kan begeleiding via de aanbieder of ontwikkelaar worden verrekend. Als er voor de klant kosten zijn voor analyse, begeleiding of aanvullende diensten, maken wij dit vooraf transparant.' },
];
---
<BaseLayout
  title="Kosten bij een huis kopen in Marokko | Maghreb Estates"
  description="Welke kosten komen er bij een huis kopen in Marokko? Overzicht van registratierechten, notariskosten, kadaster en de terugkerende lasten na aankoop."
  path={path}
  schema={[faqSchema(faqs), articleSchema({ titel: 'Kosten bij een huis kopen in Marokko', beschrijving: 'Overzicht van de kosten bij het kopen van een huis in Marokko.', path })]}
>
  <Hero
    image="/images/villa5.jpg"
    compact
    eyebrow="Kosten"
    title="De kosten van een<br /><em>huis kopen in Marokko</em>"
    sub="Naast de koopsom krijgt u te maken met officiële aankoopkosten en met terugkerende lasten daarna. Hier ziet u de opbouw in hoofdlijnen."
    ctas={[{ label: 'Plan adviesgesprek', href: '/adviesgesprek/', primary: true }]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Kosten', href: path }]} />
  <AiBlocks path={path} />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <p>Naast de koopsom krijgt u te maken met <strong>officiële aankoopkosten</strong>, zoals registratierechten, notariskosten, kadaster of inschrijving en eventuele bank- of administratieve kosten. De exacte kosten verschillen per dossier, aankoopvorm en object.</p>

      <h2>De officiële kostenposten bij aankoop</h2>
      <ul>
        <li><strong>Registratierechten (droits d’enregistrement):</strong> de grootste post. Voor een <strong>gebouwde woning</strong> geldt in beginsel <strong>4%</strong>; voor <strong>onbebouwde grond</strong> <strong>5%</strong>; voor de eerste verkoop van bepaalde <strong>sociale woningen</strong> <strong>3%</strong>.</li>
        <li><strong>Notariskosten (honoraires):</strong> in de praktijk circa <strong>0,5–1%</strong> van de koopsom, met een praktisch minimum rond <strong>3.000 MAD</strong>, plus zegel- en administratiekosten.</li>
        <li><strong>Kadaster / inschrijving (conservation foncière):</strong> indicatief <strong>±1–1,5%</strong> plus kleine vaste kosten, voor de inschrijving van de <a href="/titre-foncier-marokko/">titre foncier</a> op uw naam.</li>
        <li><strong>Zegelrechten (droits de timbre):</strong> doorgaans kleine vaste bedragen.</li>
        <li><strong>Bank- en valutakosten:</strong> afhankelijk van uw bank en de gekozen overboekingsroute.</li>
      </ul>
      <p>Op nieuwbouw van een ontwikkelaar zit doorgaans <strong>20% TVA</strong> in de prijs verdisconteerd. Sinds 1 juli 2026 geldt bij transacties boven <strong>300.000 MAD</strong> een extra registratierecht van 2% als de betaalmodaliteiten niet correct in de akte staan. Betaal daarom via de notaris en zorg dat de betalingsroute correct is gedocumenteerd.</p>

      <h2>Het koopcontract (compromis de vente)</h2>
      <p>Bij het voorlopig koopcontract betaalt u meestal een aanbetaling, in de praktijk vaak <strong>5–10%</strong> van de koopsom. Leg bedrag, voorwaarden en betalingsroute duidelijk vast en laat de documenten vooraf beoordelen. Meer hierover staat in het overzicht van de <a href="/koopcontract-marokko-vastgoed/">contractvoorwaarden</a>.</p>

      <MarketDisclaimer />

      <h2>Terugkerende kosten na de aankoop</h2>
      <p>Reken naast de aankoop ook met de vaste lasten die daarna volgen. Deze verschillen sterk per stad, wijk en objecttype.</p>
      <ul class="checks">
        <li><strong>Lokale belastingen:</strong> onder meer de taxe de services communaux, berekend over de huurwaarde van de woning.</li>
        <li><strong>Servicekosten (syndic):</strong> bij appartementen en residenties, afhankelijk van lift, bewaking, zwembad en conciërge.</li>
        <li><strong>Onderhoud:</strong> zeker aan de kust een reële post door de zilte lucht.</li>
        <li><strong>Verzekering:</strong> opstal en inboedel, afhankelijk van gebruik en objecttype.</li>
        <li><strong>Aansluitkosten:</strong> water en elektriciteit bij eerste ingebruikname.</li>
      </ul>

      <h2>Onze rol en vergoeding</h2>
      <p>Onze rol en vergoeding worden vooraf duidelijk besproken. Bij sommige projecten kan begeleiding via de aanbieder of ontwikkelaar worden verrekend. Als er voor de klant kosten zijn voor analyse, begeleiding of aanvullende diensten, maken wij dit vooraf transparant.</p>

      <div class="warn">
        <strong>Indicatief overzicht.</strong>
        <p>Deze informatie is indicatief en geen fiscaal of juridisch advies. Kosten worden per dossier opnieuw gecontroleerd. Vraag vóór ondertekening altijd een gespecificeerd kostenblad bij de notaris.</p>
      </div>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over de kosten" />
  <LeadCta path={path} />
</BaseLayout>

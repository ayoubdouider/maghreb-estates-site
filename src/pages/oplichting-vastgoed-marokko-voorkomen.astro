---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import CtaInline from '../components/CtaInline.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';
import { faqSchema, articleSchema } from '../data/schema';

const path = '/oplichting-vastgoed-marokko-voorkomen/';
const faqs = [
  { q: 'Hoe vaak komt oplichting bij vastgoed in Marokko voor?', a: 'Harde cijfers ontbreken, maar de meest voorkomende problemen zijn bekend: verkoop zonder geldige eigendomstitel, dubbele verkoop, een “verkoper” die niet de echte eigenaar is, en aanbetalingen die buiten de notaris om verdwijnen. Met de juiste controles zijn deze risico’s grotendeels te vermijden.' },
  { q: 'Wat is de belangrijkste manier om oplichting te voorkomen?', a: 'Verifieer altijd de titre foncier bij het kadaster en controleer of de verkoper daadwerkelijk de geregistreerde eigenaar is. Betaal nooit informeel; alle betalingen lopen via de notaris. Dit alleen al sluit de meeste vormen van oplichting uit.' },
  { q: 'Is kopen via familie of een kennis veiliger?', a: 'Niet per se. Juist informele afspraken via familie of kennissen leiden vaak tot onduidelijkheid en conflicten. Een zakelijke, officiële aanpak via de notaris beschermt zowel u als de relatie.' },
  { q: 'Waar moet ik op letten bij nieuwbouw en off-plan?', a: 'Controleer de projectontwikkelaar, de grondtitel, de bouwvergunning en of uw termijnbetalingen aan bouwfasen gekoppeld en beschermd zijn. Lees onze pagina over off-plan vastgoed en nieuwbouwprojecten controleren.' },
  { q: 'Kan Maghreb Estates een aanbieder of object voor mij controleren?', a: 'Ja. Wij doen due diligence op het object, de eigendomstitel en de aanbieder, zodat u weet of het klopt vóór u tekent of betaalt.' },
];
---
<BaseLayout
  title="Oplichting bij vastgoed in Marokko voorkomen | Maghreb Estates"
  description="Hoe voorkomt u oplichting bij vastgoed in Marokko? De meest voorkomende trucs, waarschuwingssignalen en concrete controles: titre foncier, notaris en dossiercontrole vóór u betaalt."
  path={path}
  schema={[faqSchema(faqs), articleSchema({ titel: 'Oplichting bij vastgoed in Marokko voorkomen', beschrijving: 'De meest voorkomende vormen van vastgoedoplichting in Marokko en hoe u ze vermijdt.', path })]}
>
  <Hero
    compact
    eyebrow="Veilig kopen"
    title="Oplichting bij vastgoed<br /><em>in Marokko voorkomen</em>"
    sub="De meest voorkomende trucs, de waarschuwingssignalen en de concrete controles die u beschermen — zodat u met vertrouwen koopt."
    image="/images/villa3.jpg"
    ctas={[
      { label: 'Laat je aankoop controleren', href: '/contact/?doel=aankoopcontrole', primary: true },
      { label: 'Download de checklist', href: '/contact/?doel=checklist' },
    ]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Oplichting voorkomen', href: path }]} />
  <AiBlocks path={path} />
  <TrustStrip />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <p>De angst voor <strong>oplichting bij vastgoed in Marokko</strong> weerhoudt veel Nederlandstalige kopers ervan de stap te zetten. Die voorzichtigheid is terecht — maar met de juiste kennis en controles zijn vrijwel alle vormen van oplichting te voorkomen. Op deze pagina leest u waar het misgaat en hoe u zich beschermt.</p>

      <h2>De meest voorkomende vormen van oplichting</h2>
      <ul>
        <li><strong>Verkoop zonder geldige eigendomstitel:</strong> een woning zonder geregistreerde <a href="/titre-foncier-marokko/">titre foncier</a>, waardoor eigendom niet vaststaat.</li>
        <li><strong>De valse eigenaar:</strong> iemand die zich voordoet als eigenaar maar dat niet is.</li>
        <li><strong>Dubbele verkoop:</strong> hetzelfde object aan meerdere kopers verkocht.</li>
        <li><strong>Verdwenen aanbetaling:</strong> een aanbetaling buiten de notaris om die nooit meer terugkomt.</li>
        <li><strong>Onbetrouwbare ontwikkelaar:</strong> bij <a href="/off-plan-vastgoed-marokko/">off-plan</a> een project dat nooit (goed) wordt opgeleverd.</li>
      </ul>

      <div class="warn">
        <strong>De gouden regel: geen betaling zonder controle en notaris.</strong>
        <p>Bijna elke oplichting valt weg zodra u twee dingen doet: de titre foncier verifiëren bij het kadaster én uitsluitend via de notaris betalen. Doe dat consequent, ook als de verkoper haast maakt of “een speciale prijs” belooft.</p>
      </div>

      <h2>Waarschuwingssignalen</h2>
      <ul class="checks">
        <li>Druk om snel een aanbetaling te doen, buiten de notaris om.</li>
        <li>Geen of onduidelijke eigendomspapieren, of uitvluchten daarover.</li>
        <li>Een prijs die “te mooi om waar te zijn” is.</li>
        <li>Alleen contant, informeel of via een tussenpersoon willen afhandelen.</li>
        <li>Geen controle door u of een onafhankelijke partij toestaan.</li>
      </ul>

      <CtaInline
        title="Twijfelt u over een aanbieder of object?"
        text="Laat het ons controleren. Wij verifiëren de eigenaar, de titel en de aanbieder — vóór u betaalt of tekent."
        label="Laat je aankoop controleren"
        href="/contact/?doel=aankoopcontrole"
      />

      <h2>Zo beschermt u zich — de controles</h2>
      <p>Onze <a href="/aankoopbegeleiding-vastgoed-marokko/">aankoopbegeleiding</a> is gebouwd op precies deze controles: verificatie van de <a href="/titre-foncier-marokko/">titre foncier</a>, controle of de verkoper de echte eigenaar is, toetsing van het <a href="/koopcontract-marokko-vastgoed/">koopcontract</a>, en alles officieel via de <a href="/notaris-marokko-vastgoed/">notaris</a>. Let ook op de <a href="/verborgen-kosten-huis-kopen-marokko/">verborgen kosten</a> en de bredere <a href="/risicos-huis-kopen-marokko/">risico’s bij een huis kopen in Marokko</a>.</p>

      <p>Koopt u <a href="/huis-kopen-marokko-vanuit-nederland/">op afstand vanuit Nederland</a>? Dan is onafhankelijke controle nog belangrijker, omdat u niet zelf ter plaatse kunt verifiëren.</p>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over oplichting voorkomen" />
  <CtaBand label="Laat je aankoop controleren" title="Koop met een gerust hart" text="Laat de aanbieder en het dossier controleren vóór u betaalt. Wij vertellen u eerlijk of het klopt." href="/contact/?doel=aankoopcontrole" />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import Bronnen from '../components/Bronnen.astro';
import MarketDisclaimer from '../components/MarketDisclaimer.astro';
import CtaInline from '../components/CtaInline.astro';
import Faq from '../components/Faq.astro';
import LeadCta from '../components/LeadCta.astro';
import VerderLezen from '../components/VerderLezen.astro';
import { steden } from '../data/steden';
import { prominenteSteden } from '../data/site';
import { stedenExtra } from '../data/stedenExtra';
import { marktdata } from '../data/marktdata';
import { faqSchema, serviceSchema } from '../data/schema';

export function getStaticPaths() {
  return steden.map((stad) => ({ params: { stad: stad.slug }, props: { stad } }));
}

const { stad } = Astro.props;
const path = `/vastgoed-${stad.slug}/`;
const prominent = prominenteSteden.some((p) => p.slug === stad.slug);
const extra = stedenExtra[stad.slug];
const md = marktdata[stad.slug];
const heeftCijfers = md && (md.appartement || md.villa || md.rekencase || md.huurYield || md.airbnb);

const faqs = prominent
  ? [
      { q: `Kan ik als buitenlandse koper vastgoed kopen in ${stad.naam}?`, a: `Ja. Buitenlandse kopers kunnen vrijwel overal in ${stad.naam} onroerend goed kopen, ook op afstand. Wij controleren de eigendomspapieren en de notarisroute, en begeleiden u in het Nederlands, Engels, Frans of Arabisch.` },
      { q: `Waar moet ik in ${stad.naam} op letten?`, a: `${stad.risicos[0]} Wij beoordelen elk object afzonderlijk op locatie, papieren, prijs en beheerbaarheid.` },
      { q: `Wat is de verhuurpotentie in ${stad.naam}?`, a: `${stad.verhuur}` },
      { q: `Kan Maghreb Estates mijn woning in ${stad.naam} beheren?`, a: `Ja. Na aankoop verzorgen wij verhuur, onderhoud en toezicht in ${stad.naam}, ook volledig op afstand.` },
    ]
  : [
      { q: `Hebben jullie objecten beschikbaar in ${stad.naam}?`, a: `Op dit moment hebben wij geen eigen objecten in ${stad.naam}. Heeft u zelf een woning, project of advertentie op het oog? Stuur ons de link — wij helpen u vanuit Marokko met de controle en afhandeling.` },
      { q: `Kan ik als buitenlandse koper een woning kopen in ${stad.naam}?`, a: `Ja. Buitenlandse kopers kunnen in ${stad.naam} kopen. Wij controleren de eigendomstitel, het contract en begeleiden de overdracht via de notaris.` },
      { q: `Waarmee kunnen jullie in ${stad.naam} helpen?`, a: `Met dossiercontrole (titre foncier), het koopcontract, de betalingsroute, de notaris en de overdracht, en met beheer na aankoop.` },
    ];
---
<BaseLayout
  title={`Vastgoed kopen in ${stad.naam} | Maghreb Estates`}
  description={`Vastgoed kopen in ${stad.naam}, Marokko? ${stad.invalshoek} Onafhankelijke begeleiding, dossiercontrole en beheer in ${stad.naam} voor internationale kopers.`}
  path={path}
  schema={[faqSchema(faqs), serviceSchema({ naam: `Vastgoed kopen in ${stad.naam}`, beschrijving: `Begeleiding bij kopen, controleren en beheren van vastgoed in ${stad.naam}, Marokko.`, path })]}
>
  <Hero
    compact
    eyebrow={`Vastgoed in ${stad.regio}`}
    title={`Vastgoed kopen in <em>${stad.naam}</em>`}
    sub={`${stad.invalshoek} Wij begeleiden internationale kopers en beoordelen elk object afzonderlijk.`}
    image="/images/villa5.jpg"
    ctas={[
      { label: 'Stuur een woning ter controle', href: '/contact/?doel=objectanalyse', primary: true },
      { label: 'Plan adviesgesprek', href: '/adviesgesprek/' },
    ]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: stad.naam, href: path }]} />
  <AiBlocks
    variant="stad"
    vraag={prominent ? `Is ${stad.naam} interessant om vastgoed te kopen?` : `Kan Maghreb Estates mij helpen met vastgoed in ${stad.naam}?`}
    antwoord={prominent
      ? `${stad.intro} Koop echter nooit voordat de eigendomstitel (titre foncier) is gecontroleerd en de overdracht officieel via de notaris verloopt.`
      : `Wij hebben op dit moment geen eigen objecten in ${stad.naam}. Heeft u zelf een woning of project gevonden? Stuur ons de link, dan helpen wij u vanuit Marokko met de dossiercontrole, de notaris en de overdracht.`}
    voorWie={`Kopers en eigenaren die actief zijn of willen worden in ${stad.naam}.`}
    watLeerJe={prominent ? `Waarom ${stad.naam} kan passen, voor wie juist niet, en waar wij op letten.` : `Waarmee wij u in ${stad.naam} kunnen helpen, ook zonder eigen aanbod.`}
    wanneerHelpen={`Met dossiercontrole, de notaris en beheer in ${stad.naam} — ook op afstand.`}
    letOp={stad.risicos[0]}
  />
  <TrustStrip />

  {prominent ? (
    <section class="section">
      <div class="container prose" style="max-width:760px">
        <p>{stad.intro}</p>

        <h2>Voor wie is {stad.naam} interessant?</h2>
        <ul class="checks">{stad.voorWie.map((v) => <li>{v}</li>)}</ul>

        {extra && (
          <>
            <h2>Voor wie is {stad.naam} minder geschikt?</h2>
            <ul>{extra.voorWieNiet.map((v) => <li>{v}</li>)}</ul>
          </>
        )}

        <h2>Voordelen en aandachtspunten</h2>
        <p>Sterke punten van {stad.naam}:</p>
        <ul class="checks">{stad.voordelen.map((v) => <li>{v}</li>)}</ul>
        <p>Aandachtspunten om mee te wegen:</p>
        <ul>{stad.risicos.map((r) => <li>{r}</li>)}</ul>

        <h2>Populaire gebieden</h2>
        <p>Deze gebieden worden vaak genoemd. Welk gebied past, hangt af van uw doel en moet per object worden beoordeeld:</p>
        <ul>{stad.gebieden.map((g) => <li><strong>{g.naam}</strong> — {g.over}.</li>)}</ul>

        <h2>Verhuurpotentie</h2>
        <p>{stad.verhuur} Wilt u verhuren of laten beheren? Bekijk <a href="/vastgoedbeheer-marokko/">vastgoedbeheer</a> en <a href="/vastgoedbeheer-marokko/">verhuurbeheer</a>.</p>

        {md && (
          <>
            <h2>Prijsindicatie &amp; rendement</h2>
            {heeftCijfers && (
              <ul>
                {md.appartement && <li><strong>Appartement (prijs/m²):</strong> {md.appartement}</li>}
                {md.villa && <li><strong>Villa/huis (prijs/m²):</strong> {md.villa}</li>}
                {md.rekencase && <li><strong>Rekenvoorbeeld totaalprijs:</strong> {md.rekencase}</li>}
                {md.huurYield && <li><strong>Huur en rendement:</strong> {md.huurYield}</li>}
                {md.airbnb && <li><strong>Toeristische verhuur:</strong> {md.airbnb}</li>}
              </ul>
            )}
            {md.opmerking && <p><em>{md.opmerking}</em></p>}
            <MarketDisclaimer compact />
          </>
        )}

        {extra && (
          <>
            <h2>Wat wij specifiek controleren in {stad.naam}</h2>
            <ul class="checks">{extra.checkFocus.map((c) => <li>{c}</li>)}</ul>
          </>
        )}

        <h2>Hoe wij u helpen in {stad.naam}</h2>
        <p>Wij zijn uw onafhankelijke aanspreekpunt: van <a href="/aankoopbegeleiding-vastgoed-marokko/">aankoopbegeleiding</a> en dossiercontrole tot de notaris en beheer na aankoop.</p>

        <CtaInline
          title={`Een woning in ${stad.naam} op het oog?`}
          text="Stuur ons de link of documenten. Wij controleren het dossier en de prijs voordat u verder gaat."
          label="Stuur een woning ter controle"
          href="/contact/?doel=objectanalyse"
        />
      </div>
    </section>
  ) : (
    <section class="section">
      <div class="container prose" style="max-width:760px">
        <p>{stad.intro}</p>

        <div class="warn">
          <strong>Op dit moment hebben wij geen objecten beschikbaar in {stad.naam}.</strong>
          <p>Heeft u een bepaald object op het oog — een woning, project of advertentie? Stuur ons een bericht. Wij helpen u vanuit Marokko met de afhandeling.</p>
        </div>

        <h2>Waarmee wij u in {stad.naam} helpen</h2>
        <ul class="checks">
          <li>Controle van de eigendomstitel (titre foncier) en of de verkoper bevoegd is.</li>
          <li>Beoordeling van het koopcontract, de aanbetaling en de betalingsroute.</li>
          <li>Begeleiding bij de notaris en de overdracht.</li>
          <li>Een reële inschatting van prijs en marktwaarde.</li>
          <li>Beheer na aankoop: verhuur, onderhoud en toezicht.</li>
        </ul>

        

        <CtaInline
          title={`Een woning in ${stad.naam} gevonden?`}
          text="Stuur ons de link of documenten. Wij helpen u met de controle en de afhandeling ter plaatse."
          label="Laat een object beoordelen"
          href="/contact/?doel=objectanalyse"
        />
      </div>
    </section>
  )}

  {prominent && <Bronnen extra={[`Marktindicaties ${stad.naam}: publieke prijsreferenties (o.a. Agenz, Yakeey, Properstar) en AirDNA — peildatum begin 2026`]} />}

  <Faq items={faqs} title={`Veelgestelde vragen over vastgoed in ${stad.naam}`} />

  <VerderLezen items={[
    { label: 'Aankoopbegeleiding', href: '/aankoopbegeleiding-vastgoed-marokko/', tekst: `Selectie, due diligence en overdracht in ${stad.naam}.` },
    { label: 'Investeringsadvies', href: '/investeren-vastgoed-marokko/', tekst: 'Netto rendement en strategie, onderbouwd met marktdata.' },
    { label: 'Markten in Marokko', href: '/vastgoed-marokko/', tekst: 'Vergelijk deze markt met andere steden en regio\u2019s.' },
    { label: 'Contact', href: '/contact/', tekst: 'Plan een vrijblijvend adviesgesprek.' },
  ]} />

  <LeadCta path={path} />
</BaseLayout>

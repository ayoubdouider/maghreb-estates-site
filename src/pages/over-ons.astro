---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Icon from '../components/Icon.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';
import { site, waLink, team } from '../data/site';
import { faqSchema } from '../data/schema';

const path = '/over-ons/';
const faqs = [
  { q: 'Wat doet Maghreb Estates precies?', a: 'Maghreb Estates begeleidt Nederlandstalige kopers en eigenaren bij het kopen, beoordelen, verhuren, beheren en verkopen van vastgoed in Marokko. Wij bieden aankoopbegeleiding, dossiercontrole, advies en vastgoedbeheer op afstand.' },
  { q: 'Voor wie werkt Maghreb Estates?', a: 'Voor Nederlanders, Belgen en Nederlands-Marokkanen die in Marokko willen kopen, investeren of hun woning willen laten beheren — voor eigen gebruik, verhuur of investering.' },
  { q: 'Zijn jullie onafhankelijk?', a: 'Ja. Onze vergoeding komt uit begeleiding, analyse of beheer, niet uit het doorduwen van een specifiek object. Klopt een dossier niet, dan adviseren wij niet te kopen.' },
  { q: 'Hoe waarborgen jullie dat een aankoop veilig is?', a: 'Wij controleren de eigendomstitel (titre foncier), toetsen het koopcontract, beoordelen bij nieuwbouw de ontwikkelaar en laten alles officieel via de notaris verlopen.' },
  { q: 'In welke talen kan ik met jullie communiceren?', a: 'Nederlands, Arabisch, Darija/Amazigh en Frans. U hoeft niets te vertalen of te interpreteren.' },
];
---
<BaseLayout
  title="Over Maghreb Estates: onafhankelijke aankoopbegeleiding in Marokko | Maghreb Estates"
  description="Maghreb Estates is opgericht voor Nederlandstalige kopers die in Marokko willen investeren zonder afhankelijk te zijn van losse tips of tussenpersonen. Liever een aankoop afraden dan verkeerd begeleiden."
  path={path}
  schema={[faqSchema(faqs)]}
>
  <Hero
    compact
    eyebrow="Over ons"
    title="Onafhankelijke begeleiding,<br /><em>eerlijk wanneer iets niet klopt</em>"
    sub="De nuchtere manier van werken uit Nederland, gecombineerd met lokale controle in Marokko."
    image="/images/villa4.jpg"
    ctas={[{ label: 'Plan gratis adviesgesprek', href: '/contact/', primary: true }]}
  />
  <Breadcrumbs items={[{ label: 'Over ons', href: path }]} />
  <TrustStrip />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <p>Maghreb Estates is opgericht voor Nederlandstalige kopers die wél in Marokko willen investeren, maar niet afhankelijk willen zijn van losse tips, familieconstructies of onduidelijke tussenpersonen. Wij combineren de nuchtere manier van werken uit Nederland met lokale controle in Marokko. Ons uitgangspunt is simpel: liever een aankoop afraden dan iemand begeleiden naar een verkeerd object.</p>
    </div>
  </section>

  <section class="section section--tinted">
    <div class="container">
      <div class="section__header section__header--center">
        <p class="eyebrow">Wie wij zijn</p>
        <h2>Mensen die de markt én uw taal kennen</h2>
      </div>
      <div class="personen">
        {team.map((p) => (
          <div class="persoon">
            <img class="persoon__foto" src={p.foto} alt={p.naam} width="92" height="92" loading="lazy" />
            <div>
              <h3>{p.naam}</h3>
              <p class="persoon__rol">{p.rol}</p>
              <p>{p.bio}</p>
              <div class="persoon__links">
                <a href={`tel:${p.telefoonHref}`}><Icon name="telefoon" size={16} /> {p.telefoon}</a>
                <a href={waLink('Hallo, ik heb een vraag over vastgoed in Marokko.', p.whatsapp)}><Icon name="chat" size={16} /> WhatsApp</a>
                <a href={`mailto:${p.email}`}><Icon name="mail" size={16} /> E-mail</a>
                {p.linkedin && <a href={p.linkedin}><Icon name="linkedin" size={16} /> LinkedIn</a>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <h2>Hoe wij verdienen</h2>
      <p>Wij werken transparant. Onze vergoeding komt uit begeleiding, analyse of beheer — niet uit het blind doorduwen van een willekeurig object. Als een aankoop niet klopt, zeggen wij dat. Ook als dat betekent dat u niet koopt.</p>

      <h2>Wanneer wij nee zeggen</h2>
      <p>Wij adviseren om niet te kopen wanneer:</p>
      <ul class="checks">
        <li>de eigendomstitel onduidelijk is;</li>
        <li>de verkoper geen volledige documenten aanlevert;</li>
        <li>betalingen buiten de notaris om moeten lopen;</li>
        <li>de vraagprijs niet logisch is;</li>
        <li>de ontwikkelaar onvoldoende betrouwbaar overkomt.</li>
      </ul>

      <h2>Bedrijfsgegevens</h2>
      <p>Maghreb Estates is officieel ingeschreven in Marokko als vennootschap met beperkte aansprakelijkheid (SARL), bij de rechtbank van Rabat.</p>
      <ul>
        <li>Handelsnaam: Maghreb Estates {site.rechtsvorm}</li>
        {site.activiteit && <li>Activiteit: {site.activiteit} (agence immobilière)</li>}
        {site.adres && <li>Adres: {site.adres}, {site.vestigingsplaats}</li>}
        {!site.adres && site.vestigingsplaats && <li>Vestigingsplaats: {site.vestigingsplaats}</li>}
        {site.rc && <li>Registre de Commerce (RC): {site.rc} — Rabat</li>}
        {site.ice && <li>ICE (Identifiant Commun de l’Entreprise): {site.ice}</li>}
        {site.kapitaal && <li>Maatschappelijk kapitaal: {site.kapitaal}</li>}
        <li>E-mail: <a href={`mailto:${site.email}`}>{site.email}</a></li>
        <li>Telefoon / WhatsApp: <a href={`tel:${site.telefoonHref}`}>{site.telefoon}</a></li>
        <li>Werkgebied: heel Marokko, vanuit Nederland en België</li>
        <li><a href="/privacybeleid/">Privacybeleid</a> · <a href="/disclaimer/">Disclaimer</a> · <a href="/algemene-voorwaarden/">Algemene voorwaarden</a></li>
      </ul>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over Maghreb Estates" />
  <CtaBand />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import CtaInline from '../components/CtaInline.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';
import { faqSchema, articleSchema } from '../data/schema';

const path = '/appartement-marokko-kopen-in-termijnen/';
const faqs = [
  { q: 'Kan ik een appartement in Marokko in termijnen kopen?', a: 'Ja, vooral bij nieuwbouw en off-plan is gespreide betaling tijdens de bouw gebruikelijk. U betaalt dan in fasen naarmate het project vordert. Bij bestaande bouw is termijnbetaling minder gangbaar en afhankelijk van afspraken met de verkoper of financiering.' },
  { q: 'Hoe werkt betaling in termijnen bij nieuwbouw?', a: 'De koopsom wordt opgedeeld in termijnen die idealiter gekoppeld zijn aan bouwfasen (bijvoorbeeld fundering, ruwbouw, oplevering). Belangrijk is dat de termijnen en uw bescherming goed in het contract staan.' },
  { q: 'Is termijnbetaling veilig?', a: 'Het kan veilig zijn, mits de ontwikkelaar betrouwbaar is, de grondtitel en vergunningen kloppen en de betalingen aan bouwfasen gekoppeld zijn. Zonder die waarborgen loopt u risico. Wij controleren dit vóór u zich verbindt.' },
  { q: 'Kan ik als Nederlander een hypotheek krijgen in Marokko?', a: 'Sommige Marokkaanse banken bieden financiering aan niet-ingezetenen, met eigen voorwaarden. Dit verschilt per bank en situatie. Laat u hierover goed adviseren; wij denken met u mee over de mogelijkheden.' },
  { q: 'Begeleiden jullie de aankoop in termijnen?', a: 'Ja. Wij controleren de ontwikkelaar, het contract en de betalingsstructuur, en begeleiden u tot de overdracht bij de notaris.' },
];
---
<BaseLayout
  title="Appartement in Marokko kopen in termijnen | Maghreb Estates"
  description="Een appartement in Marokko kopen in termijnen? Zo werkt gespreide betaling bij nieuwbouw, waar u op moet letten en hoe u veilig instapt. Nederlandstalige begeleiding en controle."
  path={path}
  schema={[faqSchema(faqs), articleSchema({ titel: 'Appartement Marokko kopen in termijnen', beschrijving: 'Gespreide betaling bij het kopen van een appartement in Marokko.', path })]}
>
  <Hero
    compact
    eyebrow="Kopen"
    title="Een appartement in Marokko<br /><em>kopen in termijnen</em>"
    sub="Gespreid betalen verlaagt de drempel — vooral bij nieuwbouw. Hoe het werkt, waar u op let en hoe u veilig instapt."
    image="/images/apt2.jpg"
    ctas={[
      { label: 'Plan gratis adviesgesprek', href: '/contact/', primary: true },
      { label: 'Laat het project controleren', href: '/contact/?doel=aankoopcontrole' },
    ]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Appartement in termijnen', href: path }]} />
  <AiBlocks path={path} />
  <TrustStrip />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <p>Een <strong>appartement in Marokko kopen in termijnen</strong> maakt vastgoed toegankelijk voor wie niet ineens het volledige bedrag wil of kan betalen. Vooral bij nieuwbouw is gespreide betaling gebruikelijk: u betaalt in fasen terwijl het project wordt gebouwd. Dat biedt kansen, maar vraagt om zorgvuldige controle.</p>

      <h2>Hoe werkt kopen in termijnen?</h2>
      <p>Bij <a href="/nieuwbouwprojecten-marokko/">nieuwbouw</a> en <a href="/off-plan-vastgoed-marokko/">off-plan projecten</a> wordt de koopsom opgedeeld in termijnen. Idealiter zijn die gekoppeld aan bouwfasen, zodat u betaalt naarmate er daadwerkelijk wordt opgeleverd. Bij bestaande bouw is termijnbetaling minder gangbaar en hangt het af van afspraken of financiering.</p>

      <h2>Voordelen</h2>
      <ul class="checks">
        <li>Lagere instapdrempel: u hoeft niet ineens alles te betalen.</li>
        <li>Gespreide financiering naast eventuele eigen middelen.</li>
        <li>Vaak keuze in afwerking bij nieuwbouw.</li>
      </ul>

      <div class="warn">
        <strong>Termijnbetaling zonder waarborgen is riskant.</strong>
        <p>Betaal alleen als de ontwikkelaar betrouwbaar is, de grondtitel (<a href="/titre-foncier-marokko/">titre foncier</a>) en vergunningen kloppen, en de termijnen aan bouwfasen zijn gekoppeld. Zorg dat uw betalingen in het contract beschermd zijn.</p>
      </div>

      <CtaInline
        title="Overweegt u termijnbetaling?"
        text="Laat het project en de betalingsstructuur controleren. Wij beoordelen of het veilig en logisch is opgezet."
        label="Laat het project controleren"
        href="/contact/?doel=aankoopcontrole"
      />

      <h2>Financiering en hypotheek</h2>
      <p>Naast termijnbetaling bij de ontwikkelaar bieden meerdere Marokkaanse banken financiering aan niet-ingezetenen (MRE), waaronder <strong>Attijariwafa bank, Bank of Africa, Chaabi Bank (Banque Populaire), BMCI</strong> en <strong>CIH</strong>. Indicatieve voorwaarden uit publieke bankinformatie:</p>
      <ul class="checks">
        <li><strong>Financiering:</strong> bij sommige profielen/producten tot <strong>100%</strong>, afhankelijk van dossier.</li>
        <li><strong>Looptijd:</strong> vaak tot circa <strong>25 jaar</strong>.</li>
        <li><strong>Rente:</strong> in 2026 grofweg <strong>±4–6%</strong>, sterk profielafhankelijk (topprofielen soms rond 4%).</li>
        <li><strong>Documenten (loondienst):</strong> identiteitsbewijs, adresbewijs, werkgeversverklaring, recente loonstroken en meestal domiciliëring van inkomen.</li>
      </ul>
      <p>Dit verschilt per bank en situatie; laat u hierover goed adviseren. Wij denken met u mee over de haalbaarheid.</p>
      <p style="font-size:14px;color:var(--text-muted)"><em>Voorwaarden en rentes zijn indicatief (begin/2026) en geen financieel advies; vraag altijd een offerte bij de bank.</em></p>

      <h2>Veilig kopen in termijnen</h2>
      <p>Wij controleren de ontwikkelaar, het <a href="/koopcontract-marokko-vastgoed/">koopcontract</a> en de betalingsstructuur als onderdeel van onze <a href="/aankoopbegeleiding-vastgoed-marokko/">aankoopbegeleiding</a>. Zie ook het complete <a href="/huis-kopen-marokko/">stappenplan om te kopen</a>, de <a href="/kosten-huis-kopen-marokko/">kosten</a> en, breder, <a href="/appartement-kopen-marokko/">appartement kopen in Marokko</a>.</p>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over kopen in termijnen" />
  <CtaBand title="Instappen met gespreide betaling?" text="Plan een gesprek. Wij leggen uit hoe termijnbetaling veilig werkt en controleren het project voor u." />
</BaseLayout>

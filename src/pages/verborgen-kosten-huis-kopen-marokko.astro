---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AiBlocks from '../components/AiBlocks.astro';
import CtaInline from '../components/CtaInline.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';
import { faqSchema, articleSchema } from '../data/schema';

const path = '/verborgen-kosten-huis-kopen-marokko/';
const faqs = [
  { q: 'Welke verborgen kosten zijn er bij een huis kopen in Marokko?', a: 'Denk aan servicekosten (syndic) bij appartementen, aansluitkosten voor water en elektra, jaarlijkse lokale belastingen (taxe d’habitation en taxe de services communaux), onderhoud, en bij nieuwbouw soms extra’s buiten de kale prijs. Wij brengen deze vooraf in kaart.' },
  { q: 'Hoeveel bedragen de totale bijkomende kosten?', a: 'Reken naast de koopsom op circa 6 tot 10% aan directe aankoopkosten (registratie, notaris, kadaster). Daarbovenop komen terugkerende kosten zoals belasting, servicekosten en onderhoud. Een compleet beeld voorkomt verrassingen.' },
  { q: 'Betaal ik jaarlijkse belasting over mijn woning in Marokko?', a: 'Ja, doorgaans zijn er lokale belastingen zoals de taxe d’habitation en de taxe de services communaux. De hoogte hangt af van de woning en het gebruik. Laat u hierover vooraf informeren.' },
  { q: 'Zijn er extra kosten bij nieuwbouw of off-plan?', a: 'Soms wel: denk aan aansluitkosten, gemeenschappelijke voorzieningen of oplevering “casco”. Controleer altijd wat wél en niet in de prijs zit. Zie onze pagina over off-plan vastgoed en nieuwbouw.' },
  { q: 'Hoe voorkom ik verrassingen achteraf?', a: 'Door vooraf een volledig kostenoverzicht te maken: aankoopkosten, terugkerende lasten en verwacht onderhoud. Dat is precies wat wij bij onze begeleiding voor u opstellen.' },
];
---
<BaseLayout
  title="Verborgen kosten huis kopen in Marokko | Maghreb Estates"
  description="Welke verborgen kosten komen kijken bij een huis kopen in Marokko? Servicekosten, lokale belastingen, aansluit- en onderhoudskosten. Krijg vooraf een compleet, transparant overzicht."
  path={path}
  schema={[faqSchema(faqs), articleSchema({ titel: 'Verborgen kosten huis kopen in Marokko', beschrijving: 'Overzicht van de verborgen en terugkerende kosten bij vastgoed in Marokko.', path })]}
>
  <Hero
    compact
    eyebrow="Veilig kopen"
    title="De verborgen kosten van<br /><em>een huis kopen in Marokko</em>"
    sub="Niet alleen de koopsom telt. Ontdek de kosten die kopers vaak over het hoofd zien — en krijg vooraf een compleet overzicht."
    image="/images/apt2.jpg"
    ctas={[
      { label: 'Download de checklist', href: '/contact/?doel=checklist', primary: true },
      { label: 'Plan gratis adviesgesprek', href: '/contact/' },
    ]}
  />
  <Breadcrumbs items={[{ label: 'Vastgoed Marokko', href: '/vastgoed-marokko/' }, { label: 'Verborgen kosten', href: path }]} />
  <AiBlocks path={path} />
  <TrustStrip />

  <section class="section">
    <div class="container prose" style="max-width:760px">
      <p>Veel kopers rekenen zich rijk op basis van de koopsom, en komen daarna voor verrassingen te staan. De <strong>verborgen kosten bij een huis kopen in Marokko</strong> zitten deels in de aankoop zelf en deels in de terugkerende lasten daarna. Een compleet beeld vooraf voorkomt teleurstellingen — en helpt u een eerlijke vergelijking te maken.</p>

      <h2>Kosten rond de aankoop</h2>
      <p>Naast de koopsom betaalt u circa <strong>6 tot 10%</strong> aan directe kosten. De opbouw (registratierechten, notaris, kadaster) leest u in detail in onze <a href="/kosten-huis-kopen-marokko/">gids over de kosten van een huis kopen in Marokko</a>. Let daarnaast op:</p>
      <ul class="checks">
        <li>Aansluitkosten voor water en elektriciteit.</li>
        <li>Eventuele makelaars- of begeleidingskosten.</li>
        <li>Bij nieuwbouw: oplevering “casco” of extra’s buiten de kale prijs.</li>
      </ul>

      <h2>Terugkerende (jaarlijkse) kosten</h2>
      <ul class="checks">
        <li><strong>Taxe d’habitation (woonbelasting):</strong> berekend over de <em>valeur locative</em> (huurwaarde). Voor uw <strong>hoofdwoning</strong> geldt een korting van <strong>75%</strong>; nieuwe hoofdwoningen kunnen 5 jaar vrijstelling krijgen. Tarieven op de belastbare huurwaarde: tot 5.000 MAD <strong>vrij</strong>, 5.001–20.000 MAD <strong>10%</strong>, 20.001–40.000 MAD <strong>20%</strong>, daarboven <strong>30%</strong>. Let op: een <strong>tweede/niet-verhuurde woning</strong> krijgt die 75%-korting doorgaans niet, dus de last ligt daar hoger.</li>
        <li><strong>Taxe de services communaux:</strong> eveneens over de valeur locative: <strong>10,5%</strong> in stedelijke zones/badplaatsen, <strong>6,5%</strong> in randzones.</li>
        <li><strong>Servicekosten (syndic):</strong> geen landelijk tarief; in moderne residenties indicatief <strong>±5–25 MAD/m²/maand</strong>, afhankelijk van lift, bewaking, zwembad en conciërge.</li>
        <li><strong>Onderhoud:</strong> zeker aan de kust (zilte lucht) een reële post.</li>
        <li><strong>Beheer:</strong> als u laat <a href="/vastgoedbeheer-marokko/">beheren</a> of <a href="/verhuurbeheer-marokko/">verhuren</a>.</li>
      </ul>

      <h2>Belasting bij verhuur en verkoop</h2>
      <ul class="checks">
        <li><strong>Huurinkomsten:</strong> volgens de officiële MRE-gids brutohuur tot <strong>30.000 MAD/jaar vrijgesteld</strong>, daarboven <strong>10%</strong> (onder 120.000 MAD) of <strong>15%</strong> (vanaf 120.000 MAD); er geldt een forfaitaire aftrek. Recente bronnen wijzen op mogelijke wijzigingen — verifieer dit bij aankoop.</li>
        <li><strong>Meerwaarde bij verkoop (TPI):</strong> in beginsel <strong>20%</strong> over de winst, met een <strong>minimum van 3%</strong> van de verkoopprijs. Vrijstellingen o.a. voor een hoofdwoning die ≥5 jaar is aangehouden.</li>
      </ul>

      <div class="warn">
        <strong>Let op bij verhuur en fiscaliteit.</strong>
        <p>Verhuurt u? Houd rekening met belasting op huurinkomsten in Marokko en aangifte in Nederland (box 3). Reken altijd met <em>netto</em> rendement. Laat u fiscaal adviseren voor uw situatie.</p>
      </div>

      <CtaInline
        title="Wilt u een compleet kostenoverzicht?"
        text="Wij stellen een transparante berekening op — aankoopkosten, jaarlijkse lasten en verwacht onderhoud — voor uw specifieke situatie."
        label="Download de checklist"
        href="/contact/?doel=checklist"
      />

      <h2>Zo voorkomt u verrassingen</h2>
      <p>Bij onze <a href="/aankoopbegeleiding-vastgoed-marokko/">aankoopbegeleiding</a> maken wij vooraf een volledig kostenplaatje, zodat u weet wat u écht betaalt — bij aankoop én daarna. Dit hoort bij het bredere beeld van de <a href="/risicos-huis-kopen-marokko/">risico’s</a> en het voorkomen van <a href="/oplichting-vastgoed-marokko-voorkomen/">oplichting</a>. Bekijk ook het <a href="/koopcontract-marokko-vastgoed/">koopcontract</a> en het complete <a href="/huis-kopen-marokko/">stappenplan om een huis te kopen</a>.</p>
    </div>
  </section>

  <Faq items={faqs} title="Veelgestelde vragen over verborgen kosten" />
  <CtaBand label="Download de checklist" title="Geen verrassingen achteraf" text="Vraag de checklist ‘Veilig vastgoed kopen in Marokko’ aan en krijg vooraf zicht op alle kosten." href="/contact/?doel=checklist" />
</BaseLayout>
